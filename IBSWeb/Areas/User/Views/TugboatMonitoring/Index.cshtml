@{
    ViewData["Title"] = "Tugboat Monitoring & Scheduling";
}

<link rel="stylesheet" href="~/css/monitoring.css">

<div class="container-fluid p-0 m-0 overflow-hidden">
    <div class="card shadow-none border-0 rounded-0">
        <div class="card-header bg-dark text-white d-flex justify-content-between align-items-center p-2 rounded-0">
            <div class="d-flex align-items-center gap-3">
                <h6 class="m-0"><i class="bi bi-calendar-range me-1"></i> Control Center</h6>
                <div class="input-group input-group-sm" style="width: 250px;">
                    <span class="input-group-text bg-secondary border-secondary text-white"><i class="bi bi-search"></i></span>
                    <input type="text" id="tugboatSearch" class="form-control bg-dark border-secondary text-white" placeholder="Search tugboat..." />
                </div>
                <div class="form-check form-switch mb-0 small">
                    <input class="form-check-input" type="checkbox" id="onlyWithSchedules" checked>
                    <label class="form-check-label text-light" for="onlyWithSchedules">Show only with schedules</label>
                </div>
            </div>
            <div class="d-flex align-items-center gap-2">
                <input type="month" id="targetDate" class="form-control form-control-sm" style="width: 150px;" value="@DateTime.Now.ToString("yyyy-MM")" />
                <button id="refreshBtn" class="btn btn-sm btn-outline-light" title="Reload Data">
                    <i class="bi bi-arrow-clockwise"></i>
                </button>
                <button class="btn btn-sm btn-outline-info" type="button" data-bs-toggle="offcanvas" data-bs-target="#offcanvasFilters" aria-controls="offcanvasFilters">
                    <i class="bi bi-filter"></i> Tugboats
                </button>
            </div>
        </div>
        <div class="card-body p-0 position-relative">
            <div id="timeline-container" class="timeline-container">
                <div class="timeline-header-row">
                    <div class="tugboat-header-col sticky-left bg-light border-bottom">Tugboat</div>
                    <div class="hours-container" id="hours-header">
                        <!-- Hours will be generated here -->
                    </div>
                </div>
                <div id="tugboat-rows-container">
                    <!-- Tugboat rows will be generated here -->
                </div>
                <div id="now-line" class="now-line"></div>
            </div>
        </div>
    </div>
</div>

<!-- Offcanvas Filters -->
<div class="offcanvas offcanvas-end" tabindex="-1" id="offcanvasFilters" aria-labelledby="offcanvasFiltersLabel">
    <div class="offcanvas-header bg-light">
        <h5 class="offcanvas-title" id="offcanvasFiltersLabel">Tugboat Selection</h5>
        <button type="button" class="btn-close" data-bs-dismiss="offcanvas" aria-label="Close"></button>
    </div>
    <div class="offcanvas-body">
        <div class="mb-3">
            <div class="input-group input-group-sm">
                <span class="input-group-text bg-light"><i class="bi bi-search"></i></span>
                <input type="text" id="sidebarTugboatSearch" class="form-control" placeholder="Search tugboat..." />
            </div>
        </div>
        <div class="mb-3 d-flex gap-2">
            <button class="btn btn-xs btn-outline-primary flex-grow-1" id="btnSelectAll">Select All</button>
            <button class="btn btn-xs btn-outline-secondary flex-grow-1" id="btnUnselectAll">Clear</button>
        </div>
        <div id="tugboatChecklist" class="list-group list-group-flush border rounded overflow-auto" style="max-height: 70vh;">
            <!-- Checkboxes will be generated here -->
        </div>
    </div>
</div>

<!-- Context Menu / Tooltip Modal -->
<div class="modal fade" id="blockDetailsModal" tabindex="-1" aria-hidden="true">
    <div class="modal-dialog modal-sm">
        <div class="modal-content shadow">
            <div class="modal-header py-2 bg-light">
                <h6 class="modal-title" id="modalTitle">Details</h6>
                <button type="button" class="btn-close" data-bs-dismiss="modal" aria-label="Close"></button>
            </div>
            <div class="modal-body py-3">
                <p class="mb-1"><strong>Customer:</strong> <span id="modalCustomer"></span></p>
                <p class="mb-1"><strong>Vessel:</strong> <span id="modalVessel"></span></p>
                <p class="mb-1"><strong>Time:</strong> <span id="modalTime"></span></p>
                <p class="mb-1"><strong>Port:</strong> <span id="modalPort"></span></p>
                <div id="modalConflict" class="alert alert-danger py-1 px-2 mt-2 small d-none">
                    <i class="bi bi-exclamation-triangle"></i> Conflict detected!
                </div>
            </div>
            <div class="modal-footer py-2 bg-light">
                <a href="#" id="modalLink" class="btn btn-sm btn-primary w-100">View Details</a>
            </div>
        </div>
    </div>
</div>

@section Scripts {
    <script src="~/js/TimelineManager.js"></script>
    <script>
        $(document).ready(function() {
            const initialData = @Html.Raw(System.Text.Json.JsonSerializer.Serialize(ViewBag.TimelineData, new System.Text.Json.JsonSerializerOptions { PropertyNamingPolicy = System.Text.Json.JsonNamingPolicy.CamelCase }));
            const manager = new TimelineManager({
                containerId: 'timeline-container',
                rowsContainerId: 'tugboat-rows-container',
                headerId: 'hours-header',
                searchId: 'tugboatSearch',
                sidebarSearchId: 'sidebarTugboatSearch',
                scheduleToggleId: 'onlyWithSchedules',
                checklistId: 'tugboatChecklist'
            });
            
            if (initialData) {
                const dateVal = $('#targetDate').val();
                manager.initData(dateVal, initialData);
            }

            const loadData = () => {
                const date = $('#targetDate').val();
                manager.load(date + "-01");
            };

            $('#targetDate, #refreshBtn').on('change click', loadData);
            $('#btnSelectAll').on('click', () => manager.toggleAll(true));
            $('#btnUnselectAll').on('click', () => manager.toggleAll(false));
            
            // Auto-refresh every 5 minutes
            setInterval(loadData, 5 * 60 * 1000);
        });
    </script>
}
