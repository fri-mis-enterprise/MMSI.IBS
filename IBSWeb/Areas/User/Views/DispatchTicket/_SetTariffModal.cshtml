@model IBS.Models.MMSI.ViewModels.TariffViewModel

<div class="modal-header bg-primary text-white">
    <h5 class="modal-title"><i class="bi bi-currency-dollar me-2"></i>Set Tariff - @Model.DispatchNumber</h5>
    <button type="button" class="btn-close btn-close-white" data-bs-dismiss="modal" aria-label="Close"></button>
</div>

<form id="setTariffForm" onsubmit="submitSetTariffForm(); return false;" asp-action="SaveTariff" asp-controller="DispatchTicket">
    <input type="hidden" asp-for="DispatchTicketId" />
    <input type="hidden" asp-for="JobOrderId" />
    <input type="hidden" asp-for="CustomerId" />
    <input type="hidden" asp-for="TotalHours" />
    <!-- Hidden fields for calculated values -->
    <input type="hidden" asp-for="DispatchBillingAmount" id="hiddenDispatchBilling" />
    <input type="hidden" asp-for="DispatchNetRevenue" id="hiddenDispatchNet" />
    <input type="hidden" asp-for="BAFBillingAmount" id="hiddenBAFBilling" />
    <input type="hidden" asp-for="BAFNetRevenue" id="hiddenBAFNet" />
    <input type="hidden" asp-for="TotalBilling" id="hiddenTotalBilling" />
    <input type="hidden" asp-for="TotalNetRevenue" id="hiddenTotalNet" />
    
    <div class="modal-body">
        <!-- Ticket Summary -->
        <div class="card bg-light mb-3">
            <div class="card-body py-2">
                <h6 class="card-subtitle mb-2 text-muted"><i class="bi bi-info-circle me-1"></i>Ticket Summary</h6>
                <div class="row g-2 small">
                    <div class="col-6">
                        <strong>Customer:</strong><br />@Model.CustomerName
                    </div>
                    <div class="col-6">
                        <strong>Vessel:</strong><br />@Model.VesselName
                    </div>
                    <div class="col-6">
                        <strong>Timeline:</strong><br />@Model.DateLeft @Model.TimeLeft - @Model.DateArrived @Model.TimeArrived
                    </div>
                    <div class="col-6">
                        <strong>Duration:</strong><br /><span class="text-primary fw-bold">@Model.TotalHours hrs</span>
                    </div>
                    @if (!string.IsNullOrEmpty(Model.ImageName))
                    {
                        <div class="col-12">
                            <a href="@Model.ImageSignedUrl" target="_blank" class="text-decoration-none">
                                <i class="bi bi-paperclip me-1"></i>View attached image
                            </a>
                        </div>
                    }
                </div>
            </div>
        </div>

        <!-- Charge Type -->
        <div class="card bg-light mb-3">
            <div class="card-body py-2">
                <div class="row align-items-center">
                    <div class="col-md-3">
                        <label class="form-label small fw-bold mb-0">Charge Type:</label>
                    </div>
                    <div class="col-md-9">
                        <div class="form-check form-check-inline">
                            <input class="form-check-input charge-type" type="radio" name="chargeType" id="perHour" value="Per hour" checked onchange="updateChargeType()">
                            <label class="form-check-label" for="perHour">Per Hour</label>
                        </div>
                        <div class="form-check form-check-inline">
                            <input class="form-check-input charge-type" type="radio" name="chargeType" id="perMove" value="Per move" onchange="updateChargeType()">
                            <label class="form-check-label" for="perMove">Per Move</label>
                        </div>
                    </div>
                </div>
            </div>
        </div>

        <!-- Tariff Rates -->
        <h6 class="border-bottom pb-2 mb-3"><i class="bi bi-calculator me-1"></i>Tariff Rates</h6>

        <div class="row g-3">
            <!-- Dispatch Charges -->
            <div class="col-md-6">
                <div class="card h-100">
                    <div class="card-header bg-primary text-white py-2">
                        <strong>Dispatch</strong>
                    </div>
                    <div class="card-body p-3">
                        <div class="mb-2">
                            <label asp-for="DispatchRate" class="form-label small fw-bold">Rate</label>
                            <div class="input-group input-group-sm">
                                <span class="input-group-text">₱</span>
                                <input asp-for="DispatchRate" type="number" step="0.01" class="form-control tariff-rate" required />
                            </div>
                            <span asp-validation-for="DispatchRate" class="text-danger small"></span>
                        </div>
                        <div class="mb-2">
                            <label asp-for="DispatchDiscount" class="form-label small fw-bold">Discount (%)</label>
                            <div class="input-group input-group-sm">
                                <input asp-for="DispatchDiscount" type="number" step="0.01" min="0" max="100" class="form-control tariff-discount" />
                                <span class="input-group-text">%</span>
                            </div>
                            <span asp-validation-for="DispatchDiscount" class="text-danger small"></span>
                        </div>
                        <hr class="my-2" />
                        <div class="mb-0">
                            <small class="text-muted">Billing Amount</small>
                            <div class="fw-bold text-primary" id="dispatchBilling">₱ 0.00</div>
                            <small class="text-muted">Net Revenue</small>
                            <div class="fw-bold" id="dispatchNet">₱ 0.00</div>
                        </div>
                    </div>
                </div>
            </div>

            <!-- BAF Charges -->
            <div class="col-md-6">
                <div class="card h-100">
                    <div class="card-header bg-primary text-white py-2">
                        <strong>BAF</strong>
                    </div>
                    <div class="card-body p-3">
                        <div class="mb-2">
                            <label asp-for="BAFRate" class="form-label small fw-bold">Rate</label>
                            <div class="input-group input-group-sm">
                                <span class="input-group-text">₱</span>
                                <input asp-for="BAFRate" type="number" step="0.01" class="form-control tariff-rate" required />
                            </div>
                            <span asp-validation-for="BAFRate" class="text-danger small"></span>
                        </div>
                        <div class="mb-2">
                            <label asp-for="BAFDiscount" class="form-label small fw-bold">Discount (%)</label>
                            <div class="input-group input-group-sm">
                                <input asp-for="BAFDiscount" type="number" step="0.01" min="0" max="100" class="form-control tariff-discount" />
                                <span class="input-group-text">%</span>
                            </div>
                            <span asp-validation-for="BAFDiscount" class="text-danger small"></span>
                        </div>
                        <hr class="my-2" />
                        <div class="mb-0">
                            <small class="text-muted">Billing Amount</small>
                            <div class="fw-bold text-primary" id="bafBilling">₱ 0.00</div>
                            <small class="text-muted">Net Revenue</small>
                            <div class="fw-bold" id="bafNet">₱ 0.00</div>
                        </div>
                    </div>
                </div>
            </div>
        </div>

        <!-- Additional Charges -->
        <div class="mt-3">
            <label asp-for="ApOtherTugs" class="form-label small fw-bold">AP/Other Tugs (Optional)</label>
            <div class="input-group input-group-sm" style="max-width: 200px;">
                <span class="input-group-text">₱</span>
                <input asp-for="ApOtherTugs" type="number" step="0.01" class="form-control" />
            </div>
            <span asp-validation-for="ApOtherTugs" class="text-danger small"></span>
        </div>

        <!-- Total Summary -->
        <div class="card bg-light mt-3">
            <div class="card-body py-3">
                <div class="row g-2">
                    <div class="col-6 text-center border-end">
                        <small class="text-muted">Total Billing</small>
                        <div class="fw-bold fs-5" id="totalBilling">₱ 0.00</div>
                    </div>
                    <div class="col-6 text-center">
                        <small class="text-muted">Total Net Revenue</small>
                        <div class="fw-bold fs-5 text-success" id="totalNet">₱ 0.00</div>
                    </div>
                </div>
            </div>
        </div>
    </div>

    <div class="modal-footer">
        <button type="button" class="btn btn-secondary" data-bs-dismiss="modal">
            <i class="bi bi-x-circle me-1"></i>Cancel
        </button>
        <button type="submit" class="btn btn-primary">
            <i class="bi bi-save me-1"></i>Save Tariff
        </button>
    </div>
</form>
