@model ServiceRequestViewModel

<style>
    .section-header {
        font-size: 1rem;
        font-weight: 600;
        margin-top: 1.5rem;
        margin-bottom: 1rem;
        padding-bottom: 0.5rem;
    }

    .duration-badge {
        font-size: 0.9rem;
        padding: 0.5rem 1rem;
    }
</style>

<form id="createTicketForm" method="post" class="row" enctype="multipart/form-data">
    <input type="hidden" asp-for="JobOrderId" />
    <div class="border-2 px-3">
        <div asp-validation-summary="ModelOnly" class="text-danger"></div>

        <!-- I. Reference Information -->
        <h5 class="section-header text-secondary border-bottom"><i class="bi bi-info-circle me-2"></i>I. Reference Information</h5>
        <div class="row">
            <div class="form-floating col-md-3 col-6 my-2">
                <input asp-for="Date" type="date" value="@DateTimeHelper.GetCurrentPhilippineTime().ToString("yyyy-MM-dd")" class="form-control border-0 shadow" id="TicketDate" placeholder=" ">
                <label asp-for="Date" for="TicketDate" class="ms-2">Date Today<span class="required text-danger">*</span></label>
                <span asp-validation-for="Date" class="text-danger"></span>
            </div>
            <div class="form-floating col-md-3 col-6 my-2">
                <input asp-for="DispatchNumber" type="text" class="form-control border-0 shadow" id="DispatchNumber" placeholder=" " maxlength="20" required>
                <label asp-for="DispatchNumber" for="DispatchNumber" class="ms-2">Dispatch/Mooring #<span class="required text-danger">*</span></label>
                <span asp-validation-for="DispatchNumber" class="text-danger"></span>
            </div>
            <div class="form-floating col-md-3 col-6 my-2">
                <input asp-for="COSNumber" type="text" class="form-control border-0 shadow" id="TicketCOSNumber" placeholder="" maxlength="10">
                <label asp-for="COSNumber" for="TicketCOSNumber" class="ms-2">COS#(Optional)</label>
                <span asp-validation-for="COSNumber" class="text-danger"></span>
            </div>
            <div class="form-floating col-md-3 col-6 my-2">
                <input asp-for="VoyageNumber" type="text" class="form-control border-0 shadow" id="TicketVoyageNumber" placeholder=" " maxlength="20">
                <label asp-for="VoyageNumber" for="TicketVoyageNumber" class="ms-2">Voyage#(Optional)</label>
                <span asp-validation-for="VoyageNumber" class="text-danger"></span>
            </div>
        </div>

        <!-- II. Timeline & Duration -->
        <div class="d-flex justify-content-between align-items-center border-bottom mt-4 mb-2">
            <h5 class="section-header text-secondary mb-0 border-0"><i class="bi bi-clock-history me-2"></i>II. Timeline & Duration</h5>
            <div id="modalDurationDisplay" class="badge bg-secondary duration-badge shadow-sm" style="display: none;">
                Duration: <span id="modalTotalHours">0</span> hours
            </div>
        </div>
        <div class="row">
            <div class="form-floating col-md-3 col-6 my-2">
                <input type="date" asp-for="DateLeft" value="@DateOnly.FromDateTime(DateTimeHelper.GetCurrentPhilippineTime()).ToString("yyyy-MM-dd")" class="form-control border-0 shadow modal-timeline-input" id="ModalDateLeft" placeholder=" " required>
                <label asp-for="DateLeft" for="ModalDateLeft" class="ms-2">Date Start<span class="required text-danger">*</span></label>
                <span asp-validation-for="DateLeft" class="text-danger"></span>
            </div>
            <div class="form-floating col-md-3 col-6 my-2">
                <input type="time" asp-for="TimeLeft" value="@TimeOnly.FromDateTime(DateTimeHelper.GetCurrentPhilippineTime()).ToString("HH\\:mm")" class="form-control border-0 shadow modal-timeline-input" id="ModalTimeLeft" placeholder=" " required>
                <label asp-for="TimeLeft" for="ModalTimeLeft" class="ms-2">Time Start<span class="required text-danger">*</span></label>
                <span asp-validation-for="TimeLeft" class="text-danger"></span>
            </div>
            <div class="form-floating col-md-3 col-6 my-2">
                <input type="date" asp-for="DateArrived" value="@DateOnly.FromDateTime(DateTimeHelper.GetCurrentPhilippineTime()).ToString("yyyy-MM-dd")" class="form-control border-0 shadow modal-timeline-input" id="ModalDateArrived" placeholder=" " required>
                <label asp-for="DateArrived" for="ModalDateArrived" class="ms-2">Date End<span class="required text-danger">*</span></label>
                <span asp-validation-for="DateArrived" class="text-danger"></span>
            </div>
            <div class="form-floating col-md-3 col-6 my-2">
                <input type="time" asp-for="TimeArrived" value="@TimeOnly.FromDateTime(DateTimeHelper.GetCurrentPhilippineTime()).ToString("HH\\:mm")" class="form-control border-0 shadow modal-timeline-input" id="ModalTimeArrived" placeholder=" " required>
                <label asp-for="TimeArrived" for="ModalTimeArrived" class="ms-2">Time End<span class="required text-danger">*</span></label>
                <span asp-validation-for="TimeArrived" class="text-danger"></span>
            </div>
        </div>

        <!-- III. Service Details -->
        <h5 class="section-header text-secondary border-bottom"><i class="bi bi-geo-alt me-2"></i>III. Service Details</h5>
        <div class="row">
            <div class="form-group col-12 my-2">
                <label class="form-label fw-bold">Customer<span class="required text-danger">*</span></label>
                <select id="ModalCustomerId" asp-for="CustomerId" asp-items="@Model.Customers" class="form-select js-select2" required>
                    <option value="">Select Customer</option>
                </select>
                <span asp-validation-for="CustomerId" class="text-danger"></span>
            </div>
        </div>
        <div class="row">
            <div class="form-group col-md-6 col-12 my-2">
                <label class="form-label fw-bold">Vessel<span class="required text-danger">*</span></label>
                <select id="ModalVesselId" asp-for="VesselId" asp-items="@Model.Vessels" class="form-select js-select2" required>
                    <option value="">Select Vessel</option>
                </select>
                <span asp-validation-for="VesselId" class="text-danger"></span>
            </div>
            <div class="form-group col-md-3 col-6 my-2">
                <label class="form-label fw-bold">Port<span class="required text-danger">*</span></label>
                <select id="ModalPortSelect" asp-for="PortId" asp-items="@Model.Ports" class="form-select js-select2" required>
                    <option value="">Select Port</option>
                </select>
                <span asp-validation-for="PortId" class="text-danger"></span>
            </div>
            <div class="form-group col-md-3 col-6 my-2">
                <label class="form-label fw-bold">Terminal<span class="required text-danger">*</span> <span id="modalTerminalLoading" class="spinner-border spinner-border-sm text-secondary ms-1" style="display:none;" role="status"></span></label>
                <select id="ModalTerminalSelect" asp-items="@Model.Terminals" asp-for="TerminalId" class="form-select js-select2" required>
                    <option value="">Select Terminal</option>
                </select>
                <span asp-validation-for="TerminalId" class="text-danger"></span>
            </div>
        </div>

        <!-- IV. Provider Details -->
        <h5 class="section-header text-secondary border-bottom"><i class="bi bi-person-badge me-2"></i>IV. Provider Details</h5>
        <div class="row">
            <div class="form-group col-md-4 col-12 my-2">
                <label class="form-label fw-bold">Activity/Service Type<span class="required text-danger">*</span></label>
                <select asp-for="ServiceId" asp-items="@Model.Services" class="form-select js-select2" required>
                    <option value="">Select Service</option>
                </select>
                <span asp-validation-for="ServiceId" class="text-danger"></span>
            </div>

            <div class="form-group col-md-4 col-6 my-2">
                <label class="form-label fw-bold">Tugboat/Service provider<span class="required text-danger">*</span></label>
                <select asp-for="TugBoatId" asp-items="@Model.Tugboats" class="form-select js-select2" required>
                    <option value="">Select Tugboat</option>
                </select>
                <span asp-validation-for="TugBoatId" class="text-danger"></span>
            </div>
            <div class="form-group col-md-4 col-6 my-2">
                <label class="form-label fw-bold">Master on Duty<span class="required text-danger">*</span></label>
                <select asp-for="TugMasterId" asp-items="@Model.TugMasters" class="form-select js-select2" required>
                    <option value="">Select Tug Master</option>
                </select>
                <span asp-validation-for="TugMasterId" class="text-danger"></span>
            </div>
        </div>

        <!-- V. Remarks & Media -->
        <h5 class="section-header text-secondary border-bottom"><i class="bi bi-chat-left-text me-2"></i>V. Media & Remarks</h5>
        <div class="row">
            <div class="form-floating col-12 my-2">
                <input asp-for="Remarks" type="text" class="form-control border-0 shadow" id="TicketRemarks" placeholder=" ">
                <label asp-for="Remarks" for="TicketRemarks" class="ms-2">Remarks(Optional)</label>
                <span asp-validation-for="Remarks" class="text-danger"></span>
            </div>
        </div>
        <div class="row">
            <div class="form-group col-md-6 col-12 my-2">
                <label for="modalImageUpload" class="form-label">Upload image of Dispatch Ticket</label>
                <input class="form-control form-control-sm border-0 shadow" id="modalImageUpload" name="imageFile" type='file' accept="image/png, image/jpg, image/jpeg"/>
            </div>
            <div class="form-group col-md-6 col-12 my-2">
                <label for="modalVideoUpload" class="form-label">Upload video of service operation</label>
                <input class="form-control form-control-sm border-0 shadow" id="modalVideoUpload" name="videoFile" type='file' accept="video/mp4, video/ogg"/>
            </div>
        </div>
    </div>
</form>

<script>
    $(document).ready(function () {
        // Initialize Select2 for modal - must have dropdownParent set
        $('#addTicketModal .js-select2').select2({
            dropdownParent: $('#addTicketModal'),
        });

        const port = $("#ModalPortSelect");
        const terminalSelectVar = $("#ModalTerminalSelect");
        const terminalLoading = $("#modalTerminalLoading");
        
        function HandlePortChange() {
            let portId = port.val();
            if (!portId) return;

            terminalLoading.show();
            $.ajax({
                url: '@Url.Action("ChangeTerminal", "DispatchTicket")',
                type: "GET",
                data: { portId: portId },
                success: function (data) {
                    terminalSelectVar.empty();
                    terminalSelectVar.append('<option value="">Select Terminal</option>');
                    if (Array.isArray(data)) {
                        $.each(data, function (index, item) {
                            terminalSelectVar.append($('<option>', { value: item.value, text: item.text }));
                        });
                    }
                    terminalSelectVar.trigger('change');
                },
                complete: function() {
                    terminalLoading.hide();
                }
            });
        }
        port.change(HandlePortChange);

        // Initial trigger for terminal loading
        if (port.val() && terminalSelectVar.children('option').length <= 1) {
            HandlePortChange();
        }

        const dateLeft = $("#ModalDateLeft");
        const timeLeft = $("#ModalTimeLeft");
        const dateArrived = $("#ModalDateArrived");
        const timeArrived = $("#ModalTimeArrived");
        const durationDisplay = $("#modalDurationDisplay");
        const totalHoursSpan = $("#modalTotalHours");

        function calculateDuration() {
            const startStr = `${dateLeft.val()}T${timeLeft.val()}`;
            const endStr = `${dateArrived.val()}T${timeArrived.val()}`;
            
            if (dateLeft.val() && timeLeft.val() && dateArrived.val() && timeArrived.val()) {
                const start = new Date(startStr);
                const end = new Date(endStr);
                
                if (!isNaN(start) && !isNaN(end)) {
                    const diffMs = end - start;
                    if (diffMs < 0) {
                        durationDisplay.removeClass("bg-secondary").addClass("bg-danger").show();
                        totalHoursSpan.text("Invalid");
                    } else {
                        const diffHrs = (diffMs / (1000 * 60 * 60)).toFixed(2);
                        durationDisplay.removeClass("bg-danger").addClass("bg-secondary").show();
                        totalHoursSpan.text(diffHrs);
                    }
                }
            }
        }

        dateLeft.change(function() {
            if (!dateArrived.val()) {
                dateArrived.val(dateLeft.val());
            }
            calculateDuration();
        });

        $(".modal-timeline-input").on("input change", calculateDuration);
        calculateDuration();
    });
</script>
