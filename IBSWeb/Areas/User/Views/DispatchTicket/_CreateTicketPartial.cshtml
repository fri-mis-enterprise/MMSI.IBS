@model ServiceRequestViewModel

<style>
    .section-header {
        font-size: 0.95rem;
        font-weight: 600;
        margin-top: 1rem;
        margin-bottom: 0.75rem;
        padding-bottom: 0.4rem;
    }

    .duration-badge {
        font-size: 0.85rem;
        padding: 0.4rem 0.8rem;
    }
    
    .form-label {
        font-size: 0.875rem;
    }
</style>

<form id="dispatchTicketForm" method="post" asp-action="@(Model.DispatchTicketId > 0 ? "EditTicket" : "Create")" asp-controller="DispatchTicket" class="row" enctype="multipart/form-data">
    <input type="hidden" asp-for="JobOrderId" />
    <input type="hidden" asp-for="DispatchTicketId" />

    <div class="px-2">
        <div asp-validation-summary="ModelOnly" class="text-danger"></div>

        <!-- I. Reference Information -->
        <h5 class="section-header text-secondary border-bottom"><i class="bi bi-info-circle me-2"></i>I. Reference Information</h5>
        <div class="row g-2">
            <div class="form-floating col-md-3 col-6">
                <input asp-for="Date" type="date" value="@(Model.Date.HasValue ? Model.Date.Value.ToString("yyyy-MM-dd") : DateTimeHelper.GetCurrentPhilippineTime().ToString("yyyy-MM-dd"))" class="form-control border-0 shadow" id="TicketDate" placeholder=" ">
                <label asp-for="Date" for="TicketDate" class="ms-2 small">Date Today<span class="required text-danger">*</span></label>
                <span asp-validation-for="Date" class="text-danger small"></span>
            </div>
            <div class="form-floating col-md-3 col-6">
                <input asp-for="DispatchNumber" type="text" class="form-control border-0 shadow" id="DispatchNumber" placeholder=" " maxlength="20" required>
                <label asp-for="DispatchNumber" for="DispatchNumber" class="ms-2 small">Dispatch<span class="required text-danger">*</span></label>
                <span asp-validation-for="DispatchNumber" class="text-danger small"></span>
            </div>
            <div class="form-floating col-md-3 col-6">
                <input asp-for="COSNumber" type="text" class="form-control border-0 shadow" id="TicketCOSNumber" placeholder="" maxlength="10">
                <label asp-for="COSNumber" for="TicketCOSNumber" class="ms-2 small">COS# (Optional)</label>
                <span asp-validation-for="COSNumber" class="text-danger small"></span>
            </div>
            <div class="form-floating col-md-3 col-6">
                <input asp-for="VoyageNumber" type="text" class="form-control border-0 shadow" id="TicketVoyageNumber" placeholder=" " maxlength="20">
                <label asp-for="VoyageNumber" for="TicketVoyageNumber" class="ms-2 small">Voyage# (Optional)</label>
                <span asp-validation-for="VoyageNumber" class="text-danger small"></span>
            </div>
        </div>

        <!-- II. Timeline & Duration -->
        <div class="d-flex justify-content-between align-items-center border-bottom mt-3 mb-2">
            <h5 class="section-header text-secondary mb-0 border-0"><i class="bi bi-clock-history me-2"></i>II. Timeline & Duration</h5>
            <div id="modalDurationDisplay" class="badge bg-secondary duration-badge shadow-sm">
                Duration: <span id="modalTotalHours">0</span> hrs
            </div>
        </div>
        <div class="row g-2">
            <div class="form-floating col-md-3 col-6">
                <input type="date" asp-for="DateLeft" value="@(Model.DateLeft.HasValue ? Model.DateLeft.Value.ToString("yyyy-MM-dd") : DateOnly.FromDateTime(DateTimeHelper.GetCurrentPhilippineTime()).ToString("yyyy-MM-dd"))" class="form-control border-0 shadow modal-timeline-input" id="ModalDateLeft" placeholder=" " required>
                <label asp-for="DateLeft" for="ModalDateLeft" class="ms-2 small">Date Start<span class="required text-danger">*</span></label>
                <span asp-validation-for="DateLeft" class="text-danger small"></span>
            </div>
            <div class="form-floating col-md-3 col-6">
                <input type="time" asp-for="TimeLeft" value="@(Model.TimeLeft.HasValue ? Model.TimeLeft.Value.ToString("HH\\:mm") : TimeOnly.FromDateTime(DateTimeHelper.GetCurrentPhilippineTime()).ToString("HH\\:mm"))" class="form-control border-0 shadow modal-timeline-input" id="ModalTimeLeft" placeholder=" " required>
                <label asp-for="TimeLeft" for="ModalTimeLeft" class="ms-2 small">Time Start<span class="required text-danger">*</span></label>
                <span asp-validation-for="TimeLeft" class="text-danger small"></span>
            </div>
            <div class="form-floating col-md-3 col-6">
                <input type="date" asp-for="DateArrived" value="@(Model.DateArrived.HasValue ? Model.DateArrived.Value.ToString("yyyy-MM-dd") : DateOnly.FromDateTime(DateTimeHelper.GetCurrentPhilippineTime()).ToString("yyyy-MM-dd"))" class="form-control border-0 shadow modal-timeline-input" id="ModalDateArrived" placeholder=" " required>
                <label asp-for="DateArrived" for="ModalDateArrived" class="ms-2 small">Date End<span class="required text-danger">*</span></label>
                <span asp-validation-for="DateArrived" class="text-danger small"></span>
            </div>
            <div class="form-floating col-md-3 col-6">
                <input type="time" asp-for="TimeArrived" value="@(Model.TimeArrived.HasValue ? Model.TimeArrived.Value.ToString("HH\\:mm") : TimeOnly.FromDateTime(DateTimeHelper.GetCurrentPhilippineTime()).ToString("HH\\:mm"))" class="form-control border-0 shadow modal-timeline-input" id="ModalTimeArrived" placeholder=" " required>
                <label asp-for="TimeArrived" for="ModalTimeArrived" class="ms-2 small">Time End<span class="required text-danger">*</span></label>
                <span asp-validation-for="TimeArrived" class="text-danger small"></span>
            </div>
        </div>

        <!-- III. Service Details -->
        <h5 class="section-header text-secondary border-bottom"><i class="bi bi-geo-alt me-2"></i>III. Service Details</h5>
        <div class="row g-2">
            <div class="form-group col-12">
                <label class="form-label fw-bold small">Customer<span class="required text-danger">*</span></label>
                <select id="ModalCustomerId" asp-for="CustomerId" asp-items="@Model.Customers" class="form-select js-select2" required>
                    <option value="">Select Customer</option>
                </select>
                <span asp-validation-for="CustomerId" class="text-danger small"></span>
            </div>
        </div>
        <div class="row g-2">
            <div class="form-group col-md-6 col-12">
                <label class="form-label fw-bold small">Vessel<span class="required text-danger">*</span></label>
                <select id="ModalVesselId" asp-for="VesselId" asp-items="@Model.Vessels" class="form-select js-select2" required>
                    <option value="">Select Vessel</option>
                </select>
                <span asp-validation-for="VesselId" class="text-danger small"></span>
            </div>
            <div class="form-group col-md-3 col-6">
                <label class="form-label fw-bold small">Port<span class="required text-danger">*</span></label>
                <select id="ModalPortSelect" asp-for="PortId" asp-items="@Model.Ports" class="form-select js-select2" required>
                    <option value="">Select Port</option>
                </select>
                <span asp-validation-for="PortId" class="text-danger small"></span>
            </div>
            <div class="form-group col-md-3 col-6">
                <label class="form-label fw-bold small">Terminal<span class="required text-danger">*</span> <span id="modalTerminalLoading" class="spinner-border spinner-border-sm text-secondary ms-1" style="display:none;" role="status"></span></label>
                <select id="ModalTerminalSelect" asp-items="@Model.Terminals" asp-for="TerminalId" class="form-select js-select2" required>
                    <option value="">Select Terminal</option>
                </select>
                <span asp-validation-for="TerminalId" class="text-danger small"></span>
            </div>
        </div>

        <!-- IV. Provider Details -->
        <h5 class="section-header text-secondary border-bottom"><i class="bi bi-person-badge me-2"></i>IV. Provider Details</h5>
        <div class="row g-2">
            <div class="form-group col-md-4 col-12">
                <label class="form-label fw-bold small">Activity/Service Type<span class="required text-danger">*</span></label>
                <select asp-for="ServiceId" asp-items="@Model.Services" class="form-select js-select2" required>
                    <option value="">Select Service</option>
                </select>
                <span asp-validation-for="ServiceId" class="text-danger small"></span>
            </div>

            <div class="form-group col-md-4 col-6">
                <label class="form-label fw-bold small">Tugboat/Service provider<span class="required text-danger">*</span></label>
                <select asp-for="TugBoatId" asp-items="@Model.Tugboats" class="form-select js-select2" required>
                    <option value="">Select Tugboat</option>
                </select>
                <span asp-validation-for="TugBoatId" class="text-danger small"></span>
            </div>
            <div class="form-group col-md-4 col-6">
                <label class="form-label fw-bold small">Master on Duty<span class="required text-danger">*</span></label>
                <select asp-for="TugMasterId" asp-items="@Model.TugMasters" class="form-select js-select2" required>
                    <option value="">Select Tug Master</option>
                </select>
                <span asp-validation-for="TugMasterId" class="text-danger small"></span>
            </div>
        </div>

        <!-- V. Remarks & Media -->
        <h5 class="section-header text-secondary border-bottom"><i class="bi bi-chat-left-text me-2"></i>V. Media & Remarks</h5>
        <div class="row g-2">
            <div class="form-floating col-12">
                <input asp-for="Remarks" type="text" class="form-control border-0 shadow" id="TicketRemarks" placeholder=" ">
                <label asp-for="Remarks" for="TicketRemarks" class="ms-2 small">Remarks (Optional)</label>
                <span asp-validation-for="Remarks" class="text-danger small"></span>
            </div>
        </div>
        <div class="row g-2">
            <div class="form-group col-md-6 col-12">
                <label for="modalImageUpload" class="form-label small">Upload image of Dispatch Ticket</label>
                <input class="form-control form-control-sm border-0 shadow" id="modalImageUpload" name="imageFile" type='file' accept="image/png, image/jpg, image/jpeg"/>

                @if (!string.IsNullOrEmpty(Model.ImageName))
                {
                    <div class="mt-1">
                        <small class="text-muted d-block text-truncate">Current: @Model.ImageName</small>
                        <div class="d-flex gap-2 mt-1">
                            <button type="button" class="btn btn-sm btn-info text-white view-image-btn" data-url="@Model.ImageSignedUrl"><i class="bi bi-eye"></i> View</button>
                        </div>
                    </div>
                }
            </div>
            <div class="form-group col-md-6 col-12">
                <label for="modalVideoUpload" class="form-label small">Upload video of service operation</label>
                <input class="form-control form-control-sm border-0 shadow" id="modalVideoUpload" name="videoFile" type='file' accept="video/mp4, video/ogg"/>

                @if (!string.IsNullOrEmpty(Model.VideoName))
                {
                     <div class="mt-1">
                        <small class="text-muted d-block text-truncate">Current: @Model.VideoName</small>
                        <div class="d-flex gap-2 mt-1">
                            <button type="button" class="btn btn-sm btn-info text-white view-video-btn" data-url="@Model.VideoSignedUrl"><i class="bi bi-play-circle"></i> Play</button>
                        </div>
                    </div>
                }
            </div>
        </div>
    </div>
</form>

<script>
    $(document).ready(function () {
        // Initialize Select2 for modal - must have dropdownParent set
        $('#addTicketModal .js-select2').select2({
            dropdownParent: $('#addTicketModal'),
        });

        const port = $("#ModalPortSelect");
        const terminalSelectVar = $("#ModalTerminalSelect");
        const terminalLoading = $("#modalTerminalLoading");
        
        function HandlePortChange() {
            let portId = port.val();
            if (!portId) return;

            terminalLoading.show();
            $.ajax({
                url: '@Url.Action("ChangeTerminal", "DispatchTicket")',
                type: "GET",
                data: { portId: portId },
                success: function (data) {
                    terminalSelectVar.empty();
                    terminalSelectVar.append('<option value="">Select Terminal</option>');
                    if (Array.isArray(data)) {
                        $.each(data, function (index, item) {
                            terminalSelectVar.append($('<option>', { value: item.value, text: item.text }));
                        });
                    }
                    // If we are editing and have a terminal ID, we might want to re-select it
                    // But usually the backend pre-populates the select list, so we might not need to do anything
                    // unless the list was empty initially.
                },
                complete: function() {
                    terminalLoading.hide();
                }
            });
        }
        port.change(HandlePortChange);

        // Only trigger port change if terminals are empty (Create mode mostly)
        // In Edit mode, the select list is usually pre-populated by the server.
        if (port.val() && terminalSelectVar.children('option').length <= 1) {
            HandlePortChange();
        }

        const dateLeft = $("#ModalDateLeft");
        const timeLeft = $("#ModalTimeLeft");
        const dateArrived = $("#ModalDateArrived");
        const timeArrived = $("#ModalTimeArrived");
        const durationDisplay = $("#modalDurationDisplay");
        const totalHoursSpan = $("#modalTotalHours");

        function calculateDuration() {
            const startStr = `${dateLeft.val()}T${timeLeft.val()}`;
            const endStr = `${dateArrived.val()}T${timeArrived.val()}`;
            
            if (dateLeft.val() && timeLeft.val() && dateArrived.val() && timeArrived.val()) {
                const start = new Date(startStr);
                const end = new Date(endStr);
                
                if (!isNaN(start) && !isNaN(end)) {
                    const diffMs = end - start;
                    if (diffMs < 0) {
                        durationDisplay.removeClass("bg-secondary").addClass("bg-danger").show();
                        totalHoursSpan.text("Invalid");
                    } else {
                        const diffHrs = (diffMs / (1000 * 60 * 60)).toFixed(2);
                        durationDisplay.removeClass("bg-danger").addClass("bg-secondary").show();
                        totalHoursSpan.text(diffHrs);
                    }
                }
            }
        }

        dateLeft.change(function() {
            // Only auto-fill end date if it's empty (Create mode)
            if (!dateArrived.val()) {
                dateArrived.val(dateLeft.val());
            }
            calculateDuration();
        });

        $(".modal-timeline-input").on("input change", calculateDuration);
        
        // Initial Calculation (for Edit mode)
        calculateDuration();
        
        // View Image Handler
        $('.view-image-btn').click(function() {
            var url = $(this).data('url');
            if (typeof Swal !== 'undefined') {
                Swal.fire({
                    imageUrl: url,
                    imageAlt: "Dispatch Ticket Image",
                    showConfirmButton: false,
                    background: 'transparent',
                    padding: 0,
                    width: 'auto',
                    heightAuto: true
                });
            } else {
                window.open(url, '_blank');
            }
        });
        
        // View Video Handler
        $('.view-video-btn').click(function() {
             var url = $(this).data('url');
             if (typeof Swal !== 'undefined') {
                 Swal.fire({
                    html: `<video width="100%" height="auto" controls autoplay><source src="${url}" type="video/mp4">Your browser does not support the video tag.</video>`,
                    showConfirmButton: false,
                    background: 'transparent',
                    width: '80%'
                });
             } else {
                 window.open(url, '_blank');
             }
        });
    });
</script>
