@model IEnumerable<IBS.Models.MMSI.JobOrder>

@{
    ViewData["Title"] = "Job Orders";
}

<link rel="stylesheet" href="~/css/index-style.css">

@{
    var isAdmin = User.IsInRole("Admin");
}

<div class="container-fluid mt-4">
    <div class="d-flex justify-content-between align-items-center bg-secondary p-3 rounded shadow">
        <h2 class="text-white m-0">@ViewData["Title"]</h2>
        <button type="button" class="btn btn-light" onclick="openCreateJobOrderModal()">
            <i class="bi bi-plus-circle"></i> Create Job Order
        </button>
    </div>

    <div class="card shadow border-0 mt-3">
        <div class="card-body p-3">
            <div class="table-responsive" style="max-height: 70vh">
                <table class="table table-hover mb-0" id="jobOrdersTable" style="width:100%">
                    <thead class="bg-light">
                        <tr>
                            <th class="text-start">Job Order #</th>
                            <th class="text-start">Date</th>
                            <th class="text-start">Customer</th>
                            <th class="text-start">Vessel</th>
                            <th class="text-start">COS #</th>
                            <th class="text-center">Tickets</th>
                            <th class="text-start">Status</th>
                            <th class="text-center" style="width: 100px;">Actions</th>
                        </tr>
                    </thead>
                    <tbody>
                        @foreach (var item in Model)
                        {
                            var isCancelled = item.Status == "Cancelled";
                            <tr>
                                <td class="text-start">
                                    <a asp-action="Details" asp-route-id="@item.JobOrderId" class="text-decoration-none text-primary fw-bold">
                                        @item.JobOrderNumber
                                    </a>
                                </td>
                                <td class="text-start">@item.Date.ToString("MMM dd, yyyy")</td>
                                <td class="text-start">
                                    <div class="text-truncate" style="max-width: 250px;" title="@item.Customer?.CustomerName">
                                        @item.Customer?.CustomerName
                                    </div>
                                </td>
                                <td class="text-start">
                                    <div class="text-truncate" style="max-width: 200px;" title="@item.Vessel?.VesselName">
                                        @item.Vessel?.VesselName
                                    </div>
                                </td>
                                <td class="text-start">
                                    <span class="text-muted">@(item.COSNumber ?? "-")</span>
                                </td>
                                <td class="text-center">
                                    <span class="badge bg-secondary">@item.DispatchTickets.Count</span>
                                </td>
                                <td class="text-start">
                                    @if (isCancelled)
                                    {
                                        <span class="badge rounded-pill bg-secondary">@item.Status</span>
                                    }
                                    else
                                    {
                                        <span class="badge rounded-pill @(item.Status == "Open" ? "bg-success" : "bg-secondary")">
                                            @item.Status
                                        </span>
                                    }
                                </td>
                                <td class="text-center">
                                    <div class="dropdown">
                                        <button class="btn btn-primary dropdown-toggle" type="button"
                                                data-bs-toggle="dropdown" aria-expanded="false"
                                                style="min-width: 100px;">
                                            Actions
                                        </button>
                                        <ul class="dropdown-menu" style="position: absolute !important; left: 0 !important;">
                                            <li>
                                                <a class="dropdown-item" asp-action="Details" asp-route-id="@item.JobOrderId">
                                                    <i class="bi bi-eye"></i> View
                                                </a>
                                            </li>
                                        </ul>
                                    </div>
                                </td>
                            </tr>
                        }
                    </tbody>
                </table>
            </div>
        </div>
    </div>
</div>

<!-- Create Job Order Modal -->
<div class="modal fade" id="createJobOrderModal" tabindex="-1" aria-labelledby="createJobOrderModalLabel" aria-hidden="true">
    <div class="modal-dialog modal-lg">
        <div class="modal-content">
            <div class="modal-header bg-primary text-white">
                <h5 class="modal-title" id="createJobOrderModalLabel">
                    <i class="bi bi-plus-circle me-2"></i>Create New Job Order
                </h5>
                <button type="button" class="btn-close btn-close-white" data-bs-dismiss="modal" aria-label="Close"></button>
            </div>
            @if (ViewBag.CreateViewModel != null)
            {
                @await Html.PartialAsync("_CreateModal", (IBS.Models.MMSI.ViewModels.JobOrderViewModel)ViewBag.CreateViewModel)
            }
            else
            {
                <div class="modal-body">
                    <div class="alert alert-warning">You don't have permission to create Job Orders.</div>
                </div>
            }
        </div>
    </div>
</div>

@section Scripts {
    <script>
        $(document).ready(function () {
            $('#jobOrdersTable').DataTable({
                responsive: true,
                order: [[0, 'desc']],
                language: {
                    search: "_INPUT_",
                    searchPlaceholder: "Search Job Orders..."
                }
            });

            // Initialize Select2 for the create modal
            $('#createJobOrderModal .js-select2').select2({
                dropdownParent: $('#createJobOrderModal'),
                width: '100%'
            });

            // Terminal loading when port changes
            $('#CreatePortId').on('change', function () {
                var portId = $(this).val();
                var terminalSelect = $('#CreateTerminalId');

                terminalSelect.empty().append('<option value="">-- Select Terminal --</option>');
                terminalSelect.trigger('change');

                if (!portId) return;

                $.ajax({
                    url: '@Url.Action("ChangeTerminal", "JobOrder", new { area = "User" })',
                    type: 'GET',
                    data: { portId: portId },
                    success: function (data) {
                        $.each(data, function (i, item) {
                            terminalSelect.append($('<option>', {
                                value: item.Value || item.value,
                                text: item.Text || item.text
                            }));
                        });
                        terminalSelect.trigger('change');
                    }
                });
            });
        });

        function openCreateJobOrderModal() {
            new bootstrap.Modal(document.getElementById('createJobOrderModal')).show();
        }

        function submitCreateJobOrderForm() {
            const form = $('#createJobOrderForm');
            if (!form[0].checkValidity()) {
                form[0].reportValidity();
                return;
            }

            Swal.fire({
                title: 'Creating Job Order...',
                text: 'Please wait',
                allowOutsideClick: false,
                didOpen: () => { Swal.showLoading(); }
            });

            $.ajax({
                url: form.attr('action'),
                type: 'POST',
                data: form.serialize(),
                success: function (response) {
                    if (response.success) {
                        Swal.fire({
                            icon: 'success',
                            title: 'Created!',
                            text: 'Job Order created successfully.',
                            timer: 2000,
                            showConfirmButton: false
                        }).then(() => {
                            window.location.href = response.redirectUrl || window.location.href;
                        });
                    } else {
                        Swal.close();
                        Swal.fire('Validation Error', 'Please check the form and try again.', 'warning');
                    }
                },
                error: function () {
                    Swal.fire('Error', 'An error occurred while creating the Job Order.', 'error');
                }
            });
        }
    </script>
}
