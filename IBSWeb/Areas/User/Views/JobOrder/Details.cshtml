@model IBS.Models.MMSI.JobOrder

@{
    ViewData["Title"] = $"Job Order {Model.JobOrderNumber}";
}

<link rel="stylesheet" href="~/css/index-style.css">

<style>
    .sticky-panel {
        position: sticky;
        top: 20px;
        max-height: calc(100vh - 150px);
        overflow-y: auto;
    }

    .badge.bg-orange {
        background-color: #fd7e14 !important;
        color: #4A1B0C !important;
    }
</style>

<div class="container-fluid mt-4">
    <!-- Header Card -->
    <div class="card shadow border-0 mb-4">
        <div class="card-header bg-primary text-white d-flex justify-content-between align-items-center p-3">
            <h5 class="m-0"><i class="bi bi-folder2-open"></i> @Model.JobOrderNumber</h5>
            <div class="d-flex gap-2">
                @if (Model.Status == "Open")
                {
                    @* FIX: Use separate TempData keys for close vs cancel warnings *@
                    @if (TempData["closeWarning"] != null)
                    {
                        <button type="button" class="btn btn-danger" onclick="$('#closeForm').submit()">
                            <i class="bi bi-lock"></i> Confirm Close
                        </button>
                    }
                    else
                    {
                        <button type="button" class="btn btn-warning" onclick="confirmClose()">
                            <i class="bi bi-lock"></i> Close Job Order
                        </button>
                    }
                    <form asp-action="Close" asp-route-id="@Model.JobOrderId" method="post" id="closeForm" class="d-none"></form>
                }
                <button type="button" class="btn btn-light" onclick="openEditJobOrderModal(@Model.JobOrderId, @(Model.DispatchTickets != null && Model.DispatchTickets.Any() ? "true" : "false"))">
                    <i class="bi bi-pencil"></i> Edit Details
                </button>
                @if (Model.Status == "Open" && User.IsInRole("Admin"))
                {
                    @* FIX: Use a hidden form for cancel so antiforgery token is included *@
                    @if (TempData["cancelWarning"] != null)
                    {
                        <button type="button" class="btn btn-outline-danger" onclick="$('#cancelForm').submit()">
                            <i class="bi bi-slash-circle"></i> Confirm Cancel
                        </button>
                    }
                    else
                    {
                        <button type="button" class="btn btn-outline-danger" onclick="confirmCancel()">
                            <i class="bi bi-slash-circle"></i> Cancel
                        </button>
                    }
                    <form asp-action="Cancel" asp-route-id="@Model.JobOrderId" method="post" id="cancelForm" class="d-none"></form>
                }
                <a asp-action="Index" class="btn btn-outline-light">
                    <i class="bi bi-arrow-left"></i> Back to List
                </a>
            </div>
        </div>
    </div>

    <!-- 2-Panel Layout -->
    <div class="row g-4">
        <!-- Left Panel: Job Order Details (35%) -->
        <div class="col-lg-4 col-md-5">
            <div class="card shadow border-0 sticky-panel">
                <div class="card-header bg-primary text-white p-3">
                    <div class="d-flex justify-content-between align-items-center">
                        <div>
                            <h6 class="m-0"><i class="bi bi-info-circle me-2"></i>Job Order Details</h6>
                        </div>
                        <span class="badge @(Model.Status == "Open" ? "bg-success" : "bg-secondary") fs-6">@Model.Status</span>
                    </div>
                </div>
                <div class="card-body p-3">
                    <!-- Job Order Information -->
                    <div class="row g-3 mb-3">
                        <div class="col-6">
                            <label class="text-muted small mb-1">Date</label>
                            <div class="fw-bold">@Model.Date.ToString("MMM dd, yyyy")</div>
                        </div>
                    </div>

                    <hr class="my-2">

                    <!-- Customer & Vessel -->
                    <div class="row g-3 mb-3">
                        <div class="col-12">
                            <label class="text-muted small mb-1">Customer</label>
                            <div class="fw-bold">@Model.Customer!.CustomerName</div>
                        </div>
                        <div class="col-12">
                            <label class="text-muted small mb-1">Vessel</label>
                            <div class="fw-bold">@Model.Vessel!.VesselName</div>
                        </div>
                    </div>

                    <hr class="my-2">

                    <!-- Location -->
                    <div class="row g-3 mb-3">
                        <div class="col-6">
                            <label class="text-muted small mb-1">Port</label>
                            <div>@(Model.Port!.PortName ?? "-")</div>
                        </div>
                        <div class="col-6">
                            <label class="text-muted small mb-1">Terminal</label>
                            <div>@(Model.Terminal!.TerminalName ?? "-")</div>
                        </div>
                    </div>

                    <hr class="my-2">

                    <!-- Voyage Details -->
                    <div class="row g-3">
                        <div class="col-6">
                            <label class="text-muted small mb-1">COS #</label>
                            <div>@(Model.COSNumber ?? "-")</div>
                        </div>
                        <div class="col-6">
                            <label class="text-muted small mb-1">Voyage #</label>
                            <div>@(Model.VoyageNumber ?? "-")</div>
                        </div>
                    </div>

                    @if (!string.IsNullOrEmpty(Model.Remarks))
                    {
                        <hr class="my-3">
                        <div>
                            <label class="text-muted small mb-1"><i class="bi bi-chat-left-text me-1"></i>Remarks</label>
                            <p class="mb-0 small text-muted">@Model.Remarks</p>
                        </div>
                    }
                </div>
            </div>
        </div>

        <!-- Right Panel: Dispatch Tickets (65%) -->
        <div class="col-lg-8 col-md-7">
            <div class="card shadow border-0">
                <div class="card-header bg-white d-flex justify-content-between align-items-center p-3">
                    <h5 class="m-0 text-primary"><i class="bi bi-list-task me-2"></i>Dispatch Tickets</h5>
                    @if (Model.Status == "Open")
                    {
                        <button type="button" class="btn btn-primary" onclick="openDispatchTicketModal()">
                            <i class="bi bi-plus-circle"></i> Add Ticket
                        </button>
                    }
                </div>
                <div class="card-body p-3">
                    <div class="table-responsive" style="max-height: 70vh">
                        <table class="table table-hover mb-0" id="ticketsTable" style="width:100%">
                            <thead class="bg-light">
                            <tr>
                                <th class="text-start">Ticket #</th>
                                <th class="text-center">Timeline</th>
                                <th class="text-start">Date</th>
                                <th class="text-start">Service</th>
                                <th class="text-start">Tugboat</th>
                                <th class="text-center">Total Hrs</th>
                                <th class="text-end">Billing</th>
                                <th class="text-start">Status</th>
                                <th class="text-center" style="width: 120px;">Actions</th>
                            </tr>
                            </thead>
                            <tbody>
                            @if (Model.DispatchTickets != null)
                            {
                                @foreach (var ticket in Model.DispatchTickets)
                                {
                                <tr>
                                    <td class="text-start">
                                        <span class="fw-bold">@ticket.DispatchNumber</span>
                                    </td>
                                    @* FIX: Null-safe timeline rendering *@
                                    <td class="text-start small">
                                        @if (ticket.DateLeft.HasValue && ticket.TimeLeft.HasValue && ticket.DateArrived.HasValue && ticket.TimeArrived.HasValue)
                                        {
                                            <span>@ticket.DateLeft.Value.ToString("MMM dd"), @ticket.TimeLeft.Value.ToString("HH:mm")</span>
                                            <span class="text-muted mx-1">→</span>
                                            <span>@ticket.DateArrived.Value.ToString("MMM dd"), @ticket.TimeArrived.Value.ToString("HH:mm")</span>
                                        }
                                        else
                                        {
                                            <span class="text-muted">-</span>
                                        }
                                    </td>
                                    <td class="text-start">@(ticket.Date?.ToString("MMM dd, yyyy") ?? "-")</td>
                                    <td class="text-start">@ticket.Service?.ServiceName</td>
                                    <td class="text-start">@ticket.Tugboat?.TugboatName</td>
                                    <td class="text-center">@ticket.TotalHours.ToString("N2")</td>
                                    @* FIX: Align billing cell to text-end to match its header *@
                                    <td class="text-end">₱ @ticket.TotalBilling.ToString("N2")</td>
                                    <td class="text-start"><span class="badge rounded-pill @GetStatusBadgeClass(ticket.Status)">@ticket.Status</span></td>
                                    <td class="text-center">
                                        <div class="d-flex justify-content-center gap-1">
                                            @* Quick View - Always visible *@
                                            <button type="button" class="btn btn-sm btn-outline-info" title="Quick View"
                                                    onclick="showTicketModal(@ticket.DispatchTicketId)">
                                                <i class="bi bi-eye"></i>
                                            </button>

                                            @* Status-based actions *@
                                            @if (ticket.Status == "For Tariff" || ticket.Status == "Pending")
                                            {
                                                <button type="button" class="btn btn-sm btn-outline-primary"
                                                        title="Set Tariff"
                                                        onclick="openSetTariffModal(@ticket.DispatchTicketId)">
                                                    <i class="bi bi-currency-dollar"></i>
                                                </button>
                                                @if (Model.Status == "Open")
                                                {
                                                    <button type="button" class="btn btn-sm btn-outline-primary"
                                                            title="Edit Ticket"
                                                            onclick="openDispatchTicketModal(@ticket.DispatchTicketId)">
                                                        <i class="bi bi-pencil"></i>
                                                    </button>
                                                }
                                            }
                                            else if (ticket.Status == "For Approval")
                                            {
                                                <button type="button" class="btn btn-sm btn-outline-success"
                                                        title="Review & Approve"
                                                        onclick="openApprovalModal(@ticket.DispatchTicketId)">
                                                    <i class="bi bi-check-circle"></i>
                                                </button>
                                                @if (Model.Status == "Open")
                                                {
                                                    <button type="button" class="btn btn-sm btn-outline-primary"
                                                            title="Edit Ticket"
                                                            onclick="openDispatchTicketModal(@ticket.DispatchTicketId)">
                                                        <i class="bi bi-pencil"></i>
                                                    </button>
                                                }
                                            }
                                            else if (ticket.Status == "Disapproved")
                                            {
                                                <button type="button" class="btn btn-sm btn-outline-warning"
                                                        title="Edit Tariff"
                                                        onclick="openEditTariffModal(@ticket.DispatchTicketId)">
                                                    <i class="bi bi-pencil"></i>
                                                </button>
                                            }
                                            else if (ticket.Status == "For Billing" || ticket.Status == "Billed")
                                            {
                                                @if (Model.Status == "Open")
                                                {
                                                    <button type="button" class="btn btn-sm btn-outline-primary"
                                                            title="Edit Ticket (Warning: Billed)"
                                                            onclick="openDispatchTicketModalWithWarning(@ticket.DispatchTicketId, '@ticket.Status')">
                                                        <i class="bi bi-pencil"></i>
                                                    </button>
                                                }
                                            }
                                        </div>
                                    </td>
                                </tr>
                                }
                            }
                            </tbody>
                        </table>
                    </div>
                </div>
            </div>
        </div>

        <!-- Ticket Details Modal -->
        <div class="modal fade" id="ticketModal" tabindex="-1" aria-labelledby="ticketModalLabel" aria-hidden="true">
            <div class="modal-dialog modal-lg">
                <div class="modal-content">
                    <div class="modal-header bg-primary text-white">
                        <h5 class="modal-title" id="ticketModalLabel">
                            <i class="bi bi-ticket-perforated me-2"></i>Dispatch Ticket - <span id="ticketModalDispatchNumber"></span>
                        </h5>
                        <button type="button" class="btn-close btn-close-white" data-bs-dismiss="modal" aria-label="Close"></button>
                    </div>
                    <div class="modal-body" id="ticketModalBody">
                        <div class="text-center py-4">
                            <div class="spinner-border text-info" role="status">
                                <span class="visually-hidden">Loading...</span>
                            </div>
                        </div>
                    </div>
                    <div class="modal-footer bg-light" id="ticketModalFooter">
                        <button type="button" class="btn btn-secondary" data-bs-dismiss="modal">Close</button>
                    </div>
                </div>
            </div>
        </div>

        <!-- Add / Edit Ticket Modal -->
        <div class="modal fade" id="addTicketModal" tabindex="-1" aria-labelledby="addTicketModalLabel"
             aria-hidden="true">
            <div class="modal-dialog modal-lg">
                <div class="modal-content">
                    <div class="modal-header bg-primary text-white">
                        <h5 class="modal-title" id="addTicketModalLabel"><i class="bi bi-plus-circle me-2"></i>Add New
                            Dispatch Ticket</h5>
                        <button type="button" class="btn-close btn-close-white" data-bs-dismiss="modal"
                                aria-label="Close"></button>
                    </div>
                    <div class="modal-body" id="addTicketModalBody">
                        <div class="text-center py-4">
                            <div class="spinner-border text-primary" role="status">
                                <span class="visually-hidden">Loading...</span>
                            </div>
                        </div>
                    </div>
                    <div class="modal-footer">
                        <button type="button" class="btn btn-secondary" data-bs-dismiss="modal">Cancel</button>
                        <button type="button" class="btn btn-primary" id="saveTicketBtn"
                                onclick="submitAddTicketForm()"><i class="bi bi-save me-1"></i> Save Ticket
                        </button>
                    </div>
                </div>
            </div>
        </div>

        <!-- Edit Job Order Modal -->
        <div class="modal fade" id="editJobOrderModal" tabindex="-1" aria-labelledby="editJobOrderModalLabel"
             aria-hidden="true">
            <div class="modal-dialog modal-lg">
                <div class="modal-content">
                    <div class="modal-header bg-primary text-white">
                        <h5 class="modal-title" id="editJobOrderModalLabel">
                            <i class="bi bi-pencil-square me-2"></i>Edit Job Order - <span id="editJobOrderNumber"></span>
                        </h5>
                        <button type="button" class="btn-close btn-close-white" data-bs-dismiss="modal"
                                aria-label="Close"></button>
                    </div>
                    <div class="modal-body" id="editJobOrderModalBody">
                        <div class="text-center py-4">
                            <div class="spinner-border text-primary" role="status">
                                <span class="visually-hidden">Loading...</span>
                            </div>
                        </div>
                    </div>
                </div>
            </div>
        </div>

        @section Scripts {
            <script>
                // Include anti-forgery token in all AJAX POST requests
                $.ajaxSetup({
                    beforeSend: function (xhr) {
                        xhr.setRequestHeader('X-Requested-With', 'XMLHttpRequest');
                        var token = $('input[name="__RequestVerificationToken"]').val();
                        if (token) {
                            xhr.setRequestHeader('RequestVerificationToken', token);
                        }
                    }
                });

                $(document).ready(function () {
                    $('#ticketsTable').DataTable({
                        responsive: true,
                        order: [[0, 'desc']],
                        language: {
                            search: "_INPUT_",
                            searchPlaceholder: "Search Tickets..."
                        }
                    });
                });

                function openDispatchTicketModal(ticketId = null) {
                    const modalElement = document.getElementById('addTicketModal');
                    const body = document.getElementById('addTicketModalBody');
                    const title = document.getElementById('addTicketModalLabel');
                    const saveBtn = document.getElementById('saveTicketBtn');

                    title.innerHTML = ticketId
                        ? '<i class="bi bi-pencil-square me-2"></i>Edit Dispatch Ticket'
                        : '<i class="bi bi-plus-circle me-2"></i>Add New Dispatch Ticket';
                    saveBtn.innerHTML = ticketId
                        ? '<i class="bi bi-check-circle me-1"></i> Update Ticket'
                        : '<i class="bi bi-save me-1"></i> Save Ticket';

                    body.innerHTML = `
                        <div class="text-center py-4">
                            <div class="spinner-border text-primary" role="status">
                                <span class="visually-hidden">Loading...</span>
                            </div>
                        </div>`;

                    const url = '@Url.Action("GetDispatchTicketPartial", "DispatchTicket")';

                    $.get(url, { id: ticketId, jobOrderId: '@Model.JobOrderId' }, function (data) {
                        if (data.indexOf('permission-denied-content') !== -1) {
                            $('#permissionDeniedModal .modal-body').html(data);
                            new bootstrap.Modal(document.getElementById('permissionDeniedModal')).show();
                        } else {
                            body.innerHTML = data;
                            const modal = new bootstrap.Modal(modalElement);
                            modal.show();
                            setTimeout(function () {
                                initializeDurationCalculation();
                            }, 200);
                        }
                    }).fail(function (xhr) {
                        if (xhr.responseText && xhr.responseText.indexOf('permission-denied-content') !== -1) {
                            $('#permissionDeniedModal .modal-body').html(xhr.responseText);
                            new bootstrap.Modal(document.getElementById('permissionDeniedModal')).show();
                        } else {
                            body.innerHTML = '<div class="alert alert-danger"><i class="bi bi-exclamation-triangle me-2"></i>Failed to load ticket form. Please try again.</div>';
                            const modal = new bootstrap.Modal(modalElement);
                            modal.show();
                        }
                    });
                }

                // FIX: Prevent infinite recursion — pass a flag to skip the warning on re-entry
                function openEditJobOrderModal(jobOrderId, hasTickets = false, skipWarning = false) {
                    if (!skipWarning && (hasTickets === "true" || hasTickets === true)) {
                        Swal.fire({
                            icon: 'warning',
                            title: 'Edit Job Order with Tickets',
                            html: `
                                <div class="text-start">
                                    <p class="mb-2"><strong>This Job Order has existing dispatch tickets.</strong></p>
                                    <p class="small text-muted mb-0">
                                        Changing details (especially Port, Terminal, or Vessel) may require you to review
                                        and update the affected tickets to ensure consistency.
                                    </p>
                                </div>
                            `,
                            showCancelButton: true,
                            confirmButtonColor: '#0d6efd',
                            cancelButtonColor: '#6c757d',
                            confirmButtonText: 'Continue Editing',
                            cancelButtonText: 'Cancel'
                        }).then((result) => {
                            if (result.isConfirmed) {
                                openEditJobOrderModal(jobOrderId, false, true);
                            }
                        });
                        return;
                    }

                    const modal = new bootstrap.Modal(document.getElementById('editJobOrderModal'));
                    const body = document.getElementById('editJobOrderModalBody');
                    const titleSpan = document.getElementById('editJobOrderNumber');

                    body.innerHTML = `
                        <div class="text-center py-4">
                            <div class="spinner-border text-primary" role="status">
                                <span class="visually-hidden">Loading...</span>
                            </div>
                        </div>`;

                    modal.show();

                    $.get('@Url.Action("EditModal", "JobOrder")', { id: jobOrderId }, function (data) {
                        body.innerHTML = data;
                        titleSpan.textContent = '@Model.JobOrderNumber';
                        setTimeout(function () {
                            initializeEditModal();
                        }, 100);
                    }).fail(function (xhr, status, error) {
                        console.error('Error loading edit form:', status, error);
                        Swal.fire({ icon: 'error', title: 'Error', text: 'Failed to load edit form. Please try again.' });
                        body.innerHTML = '<div class="alert alert-danger">Error loading form. Please try again.</div>';
                    });
                }

                function submitEditJobOrderForm() {
                    const form = $('#editJobOrderForm');
                    if (form.length === 0) return;

                    if (!form[0].checkValidity()) {
                        form[0].reportValidity();
                        return;
                    }

                    Swal.fire({
                        title: 'Saving Changes...',
                        text: 'Please wait',
                        allowOutsideClick: false,
                        didOpen: () => { Swal.showLoading(); }
                    });

                    $.ajax({
                        url: form.attr('action'),
                        type: 'POST',
                        data: form.serialize(),
                        success: function (response) {
                            if (response.success) {
                                Swal.fire({
                                    icon: 'success',
                                    title: 'Saved!',
                                    text: 'Job Order updated successfully.',
                                    timer: 2000,
                                    showConfirmButton: false
                                }).then(() => {
                                    window.location.href = response.redirectUrl || window.location.href;
                                });
                            } else {
                                Swal.close();
                                $('#editJobOrderModal .modal-content').html(response);
                                $('#editJobOrderModal .js-select2').select2({
                                    dropdownParent: $('#editJobOrderModal'),
                                    width: '100%'
                                });
                            }
                        },
                        error: function (xhr, status, error) {
                            console.error('Error saving job order:', status, error);
                            Swal.fire('Error', 'An error occurred while saving changes.', 'error');
                        }
                    });
                }

                function initializeEditModal() {
                    $('#editJobOrderModal .js-select2').select2({
                        dropdownParent: $('#editJobOrderModal'),
                        width: '100%'
                    });

                    $('#EditPortId').off('change').on('change', function () {
                        var portId = $(this).val();
                        var terminalSelect = $('#EditTerminalId');

                        if (!portId) {
                            terminalSelect.empty().append('<option value="">-- Select Terminal --</option>').trigger('change');
                            return;
                        }

                        terminalSelect.empty().append('<option value="">Loading...</option>').trigger('change');

                        $.ajax({
                            url: '@Url.Action("ChangeTerminal", "JobOrder")',
                            type: 'GET',
                            data: { portId: portId },
                            success: function (data) {
                                terminalSelect.empty().append('<option value="">-- Select Terminal --</option>');
                                $.each(data, function (i, item) {
                                    terminalSelect.append($('<option>', {
                                        value: item.Value || item.value,
                                        text: item.Text || item.text
                                    }));
                                });
                                terminalSelect.trigger('change');
                            },
                            error: function () {
                                terminalSelect.empty().append('<option value="">Error loading terminals</option>').trigger('change');
                            }
                        });
                    });

                    var initialPortId = $('#EditPortId').val();
                    if (initialPortId && $('#EditTerminalId').children('option').length <= 1) {
                        setTimeout(function () {
                            $('#EditPortId').trigger('change');
                        }, 200);
                    }
                }

                function openDispatchTicketModalWithWarning(ticketId, status) {
                    Swal.fire({
                        icon: 'warning',
                        title: 'Edit Billed Ticket',
                        html: `<p>This ticket has status <strong class="text-primary">${status}</strong>.</p>
                               <p class="small text-muted">Editing this ticket may affect billing records. Make sure to update all related information correctly.</p>`,
                        showCancelButton: true,
                        confirmButtonColor: '#0d6efd',
                        cancelButtonColor: '#6c757d',
                        confirmButtonText: 'Yes, edit anyway',
                        cancelButtonText: 'Cancel'
                    }).then((result) => {
                        if (result.isConfirmed) {
                            openDispatchTicketModal(ticketId);
                        }
                    });
                }

                function submitAddTicketForm() {
                    var form = $('#dispatchTicketForm');
                    if (form.length === 0) return;

                    if (!form[0].checkValidity()) {
                        form[0].reportValidity();
                        return;
                    }

                    Swal.fire({
                        title: 'Saving Ticket...',
                        text: 'Please wait',
                        allowOutsideClick: false,
                        didOpen: () => { Swal.showLoading(); }
                    });

                    form.submit();
                }

                function initializeDurationCalculation() {
                    const checkExist = setInterval(function () {
                        let dateLeftInput = $('#ModalDateLeft, [name="DateLeft"]');
                        let timeLeftInput = $('#ModalTimeLeft, [name="TimeLeft"]');
                        let dateArrivedInput = $('#ModalDateArrived, [name="DateArrived"]');
                        let timeArrivedInput = $('#ModalTimeArrived, [name="TimeArrived"]');
                        let durationBadge = $('#modalDurationDisplay');
                        let durationDisplay = $('#modalTotalHours');

                        if (dateLeftInput.length && timeLeftInput.length &&
                            dateArrivedInput.length && timeArrivedInput.length &&
                            durationBadge.length && durationDisplay.length) {

                            clearInterval(checkExist);

                            dateLeftInput.add(timeLeftInput).add(dateArrivedInput).add(timeArrivedInput).on('change input', function () {
                                calculateDuration();
                            });

                            calculateDuration();
                        }
                    }, 100);

                    function calculateDuration() {
                        let dateLeft    = $('#ModalDateLeft').val()    || $('[name="DateLeft"]').val();
                        let timeLeft    = $('#ModalTimeLeft').val()    || $('[name="TimeLeft"]').val();
                        let dateArrived = $('#ModalDateArrived').val() || $('[name="DateArrived"]').val();
                        let timeArrived = $('#ModalTimeArrived').val() || $('[name="TimeArrived"]').val();
                        let durationBadge   = $('#modalDurationDisplay');
                        let durationDisplay = $('#modalTotalHours');

                        if (!dateLeft || !timeLeft || !dateArrived || !timeArrived) {
                            durationDisplay.text('0');
                            return;
                        }

                        const startDateTime = new Date(`${dateLeft}T${timeLeft}`);
                        const endDateTime   = new Date(`${dateArrived}T${timeArrived}`);

                        if (endDateTime < startDateTime) {
                            durationDisplay.text('Invalid (End before Start)');
                            durationBadge.removeClass('bg-secondary').addClass('bg-danger');
                            return;
                        }

                        const diffHrs = ((endDateTime - startDateTime) / 3600000).toFixed(2);
                        durationDisplay.text(diffHrs);
                        durationBadge.removeClass('bg-danger').addClass('bg-secondary');
                    }
                }

                function confirmClose() {
                    Swal.fire({
                        title: 'Close Job Order?',
                        text: "Closing this Job Order will prevent adding new tickets to it.",
                        icon: 'warning',
                        showCancelButton: true,
                        confirmButtonColor: '#ffc107',
                        cancelButtonColor: '#6c757d',
                        confirmButtonText: 'Yes, close it!'
                    }).then((result) => {
                        if (result.isConfirmed) {
                            $('#closeForm').submit();
                        }
                    });
                }

                function confirmCancel() {
                    var htmlContent = `
                        <div class="text-start">
                            <p class="mb-2"><strong>This will:</strong></p>
                            <ul class="mb-2">
                                <li>Mark Job Order as "Cancelled"</li>
                                <li>Prevent adding new dispatch tickets</li>
                                <li>Affect existing tickets</li>
                            </ul>
                            <p class="text-danger small mb-0">
                                Admin-only action. Tickets in billing process (For Billing/Billed) will block cancellation.
                            </p>
                        </div>
                    `;

                    Swal.fire({
                        icon: 'warning',
                        title: 'Admin Action: Cancel Job Order?',
                        html: htmlContent,
                        showCancelButton: true,
                        confirmButtonColor: '#dc3545',
                        cancelButtonColor: '#6c757d',
                        confirmButtonText: 'Yes, cancel it!',
                        cancelButtonText: 'Review'
                    }).then((result) => {
                        if (result.isConfirmed) {
                            // FIX: Submit the hidden cancel form instead of raw $.post,
                            // so the antiforgery token is included automatically.
                            $('#cancelForm').submit();
                        }
                    });
                }

                // Server-side TempData messages
                @if (TempData.Peek("error") != null)
                {
                    <text>
                    Swal.fire({
                        icon: 'error',
                        title: 'Error',
                        html: '@Html.Raw(TempData.Peek("error"))',
                        confirmButtonColor: '#d33'
                    });
                    </text>
                }
                @if (TempData.Peek("success") != null)
                {
                    <text>
                    Swal.fire({
                        icon: 'success',
                        title: 'Success',
                        text: '@TempData.Peek("success")',
                        timer: 3000,
                        showConfirmButton: false
                    });
                    </text>
                }
                @* FIX: Show close warning separately from cancel warning *@
                @if (TempData.Peek("closeWarning") != null)
                {
                    <text>
                    Swal.fire({
                        icon: 'warning',
                        title: 'Warning',
                        html: '@Html.Raw(TempData.Peek("closeWarning"))',
                        confirmButtonColor: '#ffc107'
                    });
                    </text>
                }
                @if (TempData.Peek("cancelWarning") != null)
                {
                    <text>
                    Swal.fire({
                        icon: 'warning',
                        title: 'Warning',
                        html: '@Html.Raw(TempData.Peek("cancelWarning"))',
                        confirmButtonColor: '#dc3545'
                    });
                    </text>
                }

