@model IBS.Models.MMSI.JobOrder

@{
    ViewData["Title"] = $"Job Order {Model.JobOrderNumber}";
}

<link rel="stylesheet" href="~/css/index-style.css">

<style>
    .sticky-panel {
        position: sticky;
        top: 20px;
        max-height: calc(100vh - 150px);
    }
</style>

<div class="container-fluid mt-4">
    <!-- Header Card -->
    <div class="card shadow border-0 mb-4">
        <div class="card-header bg-primary text-white d-flex justify-content-between align-items-center p-3">
            <h5 class="m-0"><i class="bi bi-folder2-open"></i> @Model.JobOrderNumber</h5>
            <div class="d-flex gap-2">
                @if (Model.Status == "Open")
                {
                    <button type="button" class="btn btn-warning" onclick="confirmClose()">
                        <i class="bi bi-lock"></i> Close Job Order
                    </button>
                    <form asp-action="Close" asp-route-id="@Model.JobOrderId" method="post" id="closeForm" class="d-none"></form>
                }
                <a asp-action="Edit" asp-route-id="@Model.JobOrderId" class="btn btn-light">
                    <i class="bi bi-pencil"></i> Edit Details
                </a>
                @if (Model.Status == "Open" && User.IsInRole("Admin"))
                {
                    <button type="button" class="btn btn-outline-danger" onclick="confirmCancel()">
                        <i class="bi bi-slash-circle"></i> Cancel
                    </button>
                    <form asp-action="Cancel" asp-route-id="@Model.JobOrderId" method="post" id="cancelForm" class="d-none"></form>
                }
                <a asp-action="Index" class="btn btn-outline-light">
                    <i class="bi bi-arrow-left"></i> Back to List
                </a>
            </div>
        </div>
    </div>

    <!-- 2-Panel Layout -->
    <div class="row g-4">
        <!-- Left Panel: Job Order Details (35%) -->
        <div class="col-lg-4 col-md-5">
            <div class="card shadow border-0 sticky-panel">
                <div class="card-header bg-primary text-white p-3">
                    <div class="d-flex justify-content-between align-items-center">
                        <div>
                            <h6 class="m-0"><i class="bi bi-info-circle me-2"></i>Job Order Details</h6>
                        </div>
                        <span class="badge @(Model.Status == "Open" ? "bg-success" : "bg-secondary") fs-6">@Model.Status</span>
                    </div>
                </div>
                <div class="card-body p-3">
                    <!-- Job Order Information -->
                    <div class="row g-3 mb-3">
                        <div class="col-6">
                            <label class="text-muted small mb-1">Date</label>
                            <div class="fw-bold">@Model.Date.ToString("MMM dd, yyyy")</div>
                        </div>
                    </div>

                    <hr class="my-2">

                    <!-- Customer & Vessel -->
                    <div class="row g-3 mb-3">
                        <div class="col-12">
                            <label class="text-muted small mb-1">Customer</label>
                            <div class="fw-bold">@Model.Customer!.CustomerName</div>
                        </div>
                        <div class="col-12">
                            <label class="text-muted small mb-1">Vessel</label>
                            <div class="fw-bold">@Model.Vessel!.VesselName</div>
                        </div>
                    </div>

                    <hr class="my-2">

                    <!-- Location -->
                    <div class="row g-3 mb-3">
                        <div class="col-6">
                            <label class="text-muted small mb-1">Port</label>
                            <div>@(Model.Port!.PortName ?? "-")</div>
                        </div>
                        <div class="col-6">
                            <label class="text-muted small mb-1">Terminal</label>
                            <div>@(Model.Terminal!.TerminalName ?? "-")</div>
                        </div>
                    </div>

                    <hr class="my-2">

                    <!-- Voyage Details -->
                    <div class="row g-3">
                        <div class="col-6">
                            <label class="text-muted small mb-1">COS #</label>
                            <div>@(Model.COSNumber ?? "-")</div>
                        </div>
                        <div class="col-6">
                            <label class="text-muted small mb-1">Voyage #</label>
                            <div>@(Model.VoyageNumber ?? "-")</div>
                        </div>
                    </div>

                    @if (!string.IsNullOrEmpty(Model.Remarks))
                    {
                        <hr class="my-3">
                        <div>
                            <label class="text-muted small mb-1"><i class="bi bi-chat-left-text me-1"></i>Remarks</label>
                            <p class="mb-0 small text-muted">@Model.Remarks</p>
                        </div>
                    }
                </div>
            </div>
        </div>

        <!-- Right Panel: Dispatch Tickets (65%) -->
        <div class="col-lg-8 col-md-7">
            <div class="card shadow border-0">
                <div class="card-header bg-white d-flex justify-content-between align-items-center p-3">
                    <h5 class="m-0 text-primary"><i class="bi bi-list-task me-2"></i>Dispatch Tickets</h5>
                    @if (Model.Status == "Open")
                    {
                        <a asp-action="Create" asp-controller="DispatchTicket" asp-route-jobOrderId="@Model.JobOrderId" class="btn btn-primary">
                            <i class="bi bi-plus-circle"></i> Add Ticket
                        </a>
                    }
                </div>
                <div class="card-body p-3">
                    <div class="table-responsive overflow-visible">
                        <table class="table table-hover mb-0" id="ticketsTable" style="width:100%">
                            <thead class="bg-light">
                                <tr>
                                    <th class="text-start">Ticket #</th>
                                    <th class="text-center">Timeline</th>
                                    <th class="text-start">Date</th>
                                    <th class="text-start">Service</th>
                                    <th class="text-start">Tugboat</th>
                                    <th class="text-center">Total Hrs</th>
                                    <th class="text-end">Billing</th>
                                    <th class="text-start">Status</th>
                                    <th class="text-center" style="width: 120px;">Actions</th>
                                </tr>
                            </thead>
                            <tbody>
                            @foreach (var ticket in Model.DispatchTickets!)
                            {
                            <tr>
                                <td class="text-start">
                                    <span class="fw-bold">@ticket.DispatchNumber</span>
                                </td>
                                <td class="text-start small">
                                    @if (ticket is { DateLeft: not null, TimeLeft: not null, DateArrived: not null, TimeArrived: not null })
                                    {
                                        <span>@ticket.DateLeft.Value.ToString("MMM dd"), @ticket.TimeLeft.Value.ToString("HH:mm")</span>
                                        <span class="text-muted mx-1">→</span>
                                        <span>@ticket.DateArrived.Value.ToString("MMM dd"), @ticket.TimeArrived.Value.ToString("HH:mm")</span>
                                    }
                                    else
                                    {
                                        <span class="text-muted">-</span>
                                    }
                                </td>
                                <td class="text-start">@(ticket.Date?.ToString("MMM dd, yyyy") ?? "-")</td>
                                <td class="text-start">@ticket.Service?.ServiceName</td>
                                <td class="text-start">@ticket.Tugboat?.TugboatName</td>
                                <td class="text-center">@ticket.TotalHours.ToString("N2")</td>
                                <td class="text-end">₱ @ticket.TotalBilling.ToString("N2")</td>
                                <td class="text-start"><span class="badge rounded-pill" data-status="@ticket.Status">@ticket.Status</span></td>
                                <td class="text-center">
                                    <div class="dropdown">
                                        <button class="btn btn-sm btn-primary dropdown-toggle" type="button" data-bs-toggle="dropdown" aria-expanded="false">
                                            Actions
                                        </button>
                                        <ul class="dropdown-menu shadow" >
                                            <li>
                                                <a asp-action="Preview" asp-controller="DispatchTicket" asp-route-id="@ticket.DispatchTicketId" class="dropdown-item" target="_blank">
                                                    <i class="bi bi-eye-fill"></i> View Ticket
                                                </a>
                                            </li>

                                            @if (ticket.Status is "For Tariff" or "Pending")
                                            {
                                                <li>
                                                    <a asp-action="SetTariff" asp-controller="DispatchTicket" asp-route-id="@ticket.DispatchTicketId" class="dropdown-item text-primary">
                                                        <i class="bi bi-currency-dollar"></i> Set Tariff
                                                    </a>
                                                </li>
                                                <li>
                                                    <button type="button" class="dropdown-item text-danger" onclick="confirmCancelTicket(@ticket.DispatchTicketId)">
                                                        <i class="bi bi-x-circle"></i> Cancel Ticket
                                                    </button>
                                                </li>
                                                @if (Model.Status == "Open")
                                                {
                                                    <li>
                                                        <a asp-action="EditTicket" asp-controller="DispatchTicket" asp-route-id="@ticket.DispatchTicketId" asp-route-jobOrderId="@Model.JobOrderId" class="dropdown-item">
                                                            <i class="bi bi-pencil"></i> Edit Ticket
                                                        </a>
                                                    </li>
                                                }
                                            }
                                            else if (ticket.Status == "For Approval")
                                            {
                                                <li>
                                                    <button type="button" class="dropdown-item text-success"
                                                            data-approve-url="@Url.Action("Approve", "DispatchTicket", new { id = ticket.DispatchTicketId })"
                                                            onclick="confirmApprove(this)">
                                                        <i class="bi bi-check-circle"></i> Approve Tariff
                                                    </button>
                                                </li>
                                                <li>
                                                    <button type="button" class="dropdown-item text-danger" onclick="confirmDisapprove(@ticket.DispatchTicketId)">
                                                        <i class="bi bi-x-circle"></i> Disapprove Tariff
                                                    </button>
                                                </li>
                                                @if (Model.Status == "Open")
                                                {
                                                    <li>
                                                        <a asp-action="EditTicket" asp-controller="DispatchTicket" asp-route-id="@ticket.DispatchTicketId" asp-route-jobOrderId="@Model.JobOrderId" class="dropdown-item">
                                                            <i class="bi bi-pencil"></i> Edit Ticket
                                                        </a>
                                                    </li>
                                                }
                                            }
                                            else if (ticket.Status == "Disapproved")
                                            {
                                                <li>
                                                    <a asp-action="EditTariff" asp-controller="DispatchTicket" asp-route-id="@ticket.DispatchTicketId" class="dropdown-item text-warning">
                                                        <i class="bi bi-pencil"></i> Edit Tariff
                                                    </a>
                                                </li>
                                            }
                                            else if (ticket.Status == "For Billing" || ticket.Status == "Billed")
                                            {
                                                @if (Model.Status == "Open")
                                                {
                                                    <li>
                                                        <a asp-action="EditTicket" asp-controller="DispatchTicket" asp-route-id="@ticket.DispatchTicketId" asp-route-jobOrderId="@Model.JobOrderId" class="dropdown-item">
                                                            <i class="bi bi-pencil"></i> Edit Ticket
                                                        </a>
                                                    </li>
                                                }
                                            }
                                        </ul>
                                    </div>
                                </td>
                            </tr>
                            }
                            </tbody>
                        </table>
                    </div>
                </div>
            </div>
        </div>

    </div>
</div>

@section Scripts {
    <script>
        const PageConfig = {
            jobOrderId: @Model.JobOrderId,
            jobOrderNumber: '@Model.JobOrderNumber',
            status: '@Model.Status',
            hasTickets: @(Model.DispatchTickets.Any() ? "true" : "false"),
            messages: {
                error:   @Json.Serialize(TempData.Peek("error")),
                success: @Json.Serialize(TempData.Peek("success"))
            }
        };

        $(document).ready(function () {
            // Apply status badge classes
            $('[data-status]').each(function() {
                const status = $(this).data('status');
                $(this).addClass(getStatusBadgeClass(status));
            });

            // Show TempData messages
            if (PageConfig.messages.error) {
                Swal.fire({
                    icon: 'error',
                    title: 'Error',
                    html: PageConfig.messages.error,
                    confirmButtonColor: '#d33'
                });
            }
            if (PageConfig.messages.success) {
                Swal.fire({
                    icon: 'success',
                    title: 'Success',
                    text: PageConfig.messages.success,
                    timer: 3000,
                    showConfirmButton: false
                });
            }
        });

        function getStatusBadgeClass(status) {
            const classes = {
                'Pending':      'bg-secondary',
                'For Tariff':   'bg-warning text-dark',
                'For Approval': 'bg-orange',
                'For Billing':  'bg-primary',
                'Billed':       'bg-success',
                'Disapproved':  'bg-danger',
                'Cancelled':    'bg-danger'
            };
            return classes[status] || 'bg-secondary';
        }

        function confirmClose() {
            Swal.fire({
                title: 'Close Job Order?',
                text: "Closing this Job Order will prevent adding new tickets to it.",
                icon: 'warning',
                showCancelButton: true,
                confirmButtonColor: '#ffc107',
                cancelButtonColor: '#6c757d',
                confirmButtonText: 'Yes, close it!'
            }).then((result) => {
                if (result.isConfirmed) {
                    $('#closeForm').submit();
                }
            });
        }

        function confirmCancel() {
            const htmlContent = `
                <div class="text-start">
                    <p class="mb-2"><strong>This will:</strong></p>
                    <ul class="mb-2">
                        <li>Mark Job Order as "Cancelled"</li>
                        <li>Prevent adding new dispatch tickets</li>
                    </ul>
                    <p class="text-danger small mb-0">
                        Admin-only action. Tickets in billing process (For Billing/Billed) will block cancellation.
                    </p>
                </div>
            `;

            Swal.fire({
                icon: 'warning',
                title: 'Cancel Job Order?',
                html: htmlContent,
                showCancelButton: true,
                confirmButtonColor: '#dc3545',
                cancelButtonColor: '#6c757d',
                confirmButtonText: 'Yes, cancel it!',
                cancelButtonText: 'Review'
            }).then((result) => {
                if (result.isConfirmed) {
                    $('#cancelForm').submit();
                }
            });
        }

        function confirmApprove(btn) {
            const url = btn.getAttribute('data-approve-url');
            Swal.fire({
                title: 'Approve Tariff?',
                text: "This ticket will be marked for billing.",
                icon: 'question',
                showCancelButton: true,
                confirmButtonColor: '#198754',
                confirmButtonText: 'Yes, approve it!'
            }).then((result) => {
                if (result.isConfirmed) {
                    window.location.href = url;
                }
            });
        }

        function confirmDisapprove(id) {
            Swal.fire({
                title: 'Disapprove Tariff',
                text: "Please provide a reason (min 10 characters):",
                input: 'text',
                inputAttributes: {
                    autocapitalize: 'off',
                    required: 'required',
                    minlength: '10'
                },
                showCancelButton: true,
                confirmButtonText: 'Submit',
                confirmButtonColor: '#dc3545',
                showLoaderOnConfirm: true,
                preConfirm: (reason) => {
                    if (!reason || reason.length < 10) {
                        Swal.showValidationMessage('Reason must be at least 10 characters');
                        return false;
                    }
                    const formData = new FormData();
                    formData.append('id', id);
                    formData.append('reason', reason);
                    formData.append('__RequestVerificationToken', $('input[name="__RequestVerificationToken"]').val());

                    return fetch('@Url.Action("DisapproveTariff", "DispatchTicket", new { area = "User" })', {
                        method: 'POST',
                        body: new URLSearchParams(formData)
                    })
                    .then(response => {
                        if (!response.ok) throw new Error(response.statusText);
                        return response.json();
                    })
                    .then(data => {
                        if (!data.success) throw new Error(data.message);
                        return data;
                    })
                    .catch(error => {
                        Swal.showValidationMessage(`Request failed: ${error}`);
                    });
                },
                allowOutsideClick: () => !Swal.isLoading()
            }).then((result) => {
                if (result.isConfirmed) {
                    Swal.fire('Disapproved!', 'The tariff has been disapproved.', 'success')
                        .then(() => location.reload());
                }
            });
        }

        function confirmCancelTicket(id) {
            Swal.fire({
                title: 'Cancel Dispatch Ticket?',
                text: "This action will mark the ticket as Cancelled.",
                icon: 'warning',
                showCancelButton: true,
                confirmButtonColor: '#dc3545',
                confirmButtonText: 'Yes, cancel it!'
            }).then((result) => {
                if (result.isConfirmed) {
                    window.location.href = '@Url.Action("Cancel", "DispatchTicket", new { area = "User" })' + '/' + id;
                }
            })
        }
    </script>
}
