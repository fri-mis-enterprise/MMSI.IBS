@model IBS.Models.MMSI.ViewModels.JobOrderViewModel

@{
    ViewData["Title"] = $"Job Order {Model.JobOrderNumber}";
}

<link rel="stylesheet" href="~/css/index-style.css">

<style>
    .sticky-panel {
        position: sticky;
        top: 20px;
        max-height: calc(100vh - 150px);
        overflow-y: auto;
    }
</style>

<div class="container-fluid mt-4">
    <!-- Header Card -->
    <div class="card shadow border-0 mb-4">
        <div class="card-header bg-secondary text-white d-flex justify-content-between align-items-center p-3">
            <h5 class="m-0"><i class="bi bi-folder2-open"></i> @Model.JobOrderNumber</h5>
            <div class="d-flex gap-2">
                @if (Model.Status == "Open")
                {
                    <form asp-action="Close" asp-route-id="@Model.JobOrderId" method="post" id="closeForm"
                          class="d-inline">
                        <input type="hidden" id="confirmCloseValue" name="confirmed" value="false" />
                        <button type="button" class="btn btn-warning" onclick="confirmClose()">
                            <i class="bi bi-lock"></i> Close Job Order
                        </button>
                    </form>
                }
                <a asp-action="Edit" asp-route-id="@Model.JobOrderId" class="btn btn-light">
                    <i class="bi bi-pencil"></i> Edit Details
                </a>
                <a asp-action="Delete" asp-route-id="@Model.JobOrderId" class="btn btn-outline-light">
                    <i class="bi bi-trash"></i> Delete
                </a>
                <a asp-action="Index" class="btn btn-outline-light">
                    <i class="bi bi-arrow-left"></i> Back to List
                </a>
            </div>
        </div>
    </div>

    <!-- 2-Panel Layout -->
    <div class="row g-4">
        <!-- Left Panel: Job Order Details (35%) -->
        <div class="col-lg-4 col-md-5">
            <div class="card shadow border-0 sticky-panel">
                <div class="card-header bg-primary text-white p-3">
                    <div class="d-flex justify-content-between align-items-center">
                        <div>
                            <h6 class="m-0"><i class="bi bi-info-circle me-2"></i>Job Order Details</h6>
                        </div>
                        <span class="badge @(Model.Status == "Open" ? "bg-success" : "bg-secondary") fs-6">@Model.Status</span>
                    </div>
                </div>
                <div class="card-body p-3">
                    <!-- Job Order Information -->
                    <div class="row g-3 mb-3">
                        <div class="col-6">
                            <label class="text-muted small mb-1">Date</label>
                            <div class="fw-bold">@Model.Date.ToString("MMM dd, yyyy")</div>
                        </div>
                    </div>
                    
                    <hr class="my-2">
                    
                    <!-- Customer & Vessel -->
                    <div class="row g-3 mb-3">
                        <div class="col-12">
                            <label class="text-muted small mb-1">Customer</label>
                            <div class="fw-bold">@Model.CustomerName</div>
                        </div>
                        <div class="col-12">
                            <label class="text-muted small mb-1">Vessel</label>
                            <div class="fw-bold">@Model.VesselName</div>
                        </div>
                    </div>
                    
                    <hr class="my-2">
                    
                    <!-- Location -->
                    <div class="row g-3 mb-3">
                        <div class="col-6">
                            <label class="text-muted small mb-1">Port</label>
                            <div>@(Model.PortName ?? "-")</div>
                        </div>
                        <div class="col-6">
                            <label class="text-muted small mb-1">Terminal</label>
                            <div>@(Model.TerminalName ?? "-")</div>
                        </div>
                    </div>
                    
                    <hr class="my-2">
                    
                    <!-- Voyage Details -->
                    <div class="row g-3">
                        <div class="col-6">
                            <label class="text-muted small mb-1">COS #</label>
                            <div>@(Model.COSNumber ?? "-")</div>
                        </div>
                        <div class="col-6">
                            <label class="text-muted small mb-1">Voyage #</label>
                            <div>@(Model.VoyageNumber ?? "-")</div>
                        </div>
                    </div>
                    
                    @if (!string.IsNullOrEmpty(Model.Remarks))
                    {
                        <hr class="my-3">
                        <div>
                            <label class="text-muted small mb-1"><i class="bi bi-chat-left-text me-1"></i>Remarks</label>
                            <p class="mb-0 small text-muted">@Model.Remarks</p>
                        </div>
                    }
                </div>
            </div>
        </div>

        <!-- Right Panel: Dispatch Tickets (65%) -->
        <div class="col-lg-8 col-md-7">
            <div class="card shadow border-0">
                <div class="card-header bg-white d-flex justify-content-between align-items-center p-3">
                    <h5 class="m-0 text-primary"><i class="bi bi-list-task me-2"></i>Dispatch Tickets</h5>
                    @if (Model.Status == "Open")
                    {
                        <button type="button" class="btn btn-primary" onclick="openDispatchTicketModal()">
                            <i class="bi bi-plus-circle"></i> Add Ticket
                        </button>
                    }
                </div>
                <div class="card-body p-3">
                    <div class="table-responsive" style="max-height: 70vh">
                        <table class="table table-hover mb-0" id="ticketsTable" style="width:100%">
                            <thead class="bg-light">
                            <tr>
                                <th class="text-start">Ticket #</th>
                                <th class="text-center">Timeline</th>
                                <th class="text-start">Date</th>
                                <th class="text-start">Service</th>
                                <th class="text-start">Tugboat</th>
                                <th class="text-center">Total Hrs</th>
                                <th class="text-end">Billing</th>
                                <th class="text-start">Status</th>
                                <th class="text-center" style="width: 120px;">Actions</th>
                            </tr>
                            </thead>
                            <tbody>
                            @foreach (var ticket in Model.DispatchTickets)
                            {
                                <tr>
                                    <td class="text-start">
                                        <span class="fw-bold">@ticket.DispatchNumber</span>
                                    </td>
                                    <td class="text-start small">
                                        <span>@ticket.DateLeft!.Value.ToString("MMM dd"), @ticket.TimeLeft!.Value.ToString("HH:mm")</span>
                                        <span class="text-muted mx-1">→</span>
                                        <span>@ticket.DateArrived!.Value.ToString("MMM dd"), @ticket.TimeArrived!.Value.ToString("HH:mm")</span>
                                    </td>
                                    <td class="text-start">@(ticket.Date?.ToString("MMM dd, yyyy") ?? "-")</td>
                                    <td class="text-start">@ticket.Service?.ServiceName</td>
                                    <td class="text-start">@ticket.Tugboat?.TugboatName</td>
                                    <td class="text-center">@ticket.TotalHours.ToString("N2")</td>
                                    <td class="text-center">₱ @ticket.TotalBilling.ToString("N2")</td>
                                    <td class="text-start"><span class="badge rounded-pill @GetStatusBadgeClass(ticket.Status)">@ticket.Status</span></td>
                                    <td class="text-center">
                                        <div class="d-flex justify-content-center gap-1">
                                            @* Quick View - Always visible *@
                                            <button type="button" class="btn btn-sm btn-outline-info" title="Quick View"
                                                    onclick="showTicketModal(@ticket.DispatchTicketId)">
                                                <i class="bi bi-eye"></i>
                                            </button>

                                            @* Status-based actions *@
                                            @if (ticket.Status == "For Tariff" || ticket.Status == "Pending")
                                            {
                                                <button type="button" class="btn btn-sm btn-outline-primary"
                                                        title="Set Tariff"
                                                        onclick="openSetTariffModal(@ticket.DispatchTicketId)">
                                                    <i class="bi bi-currency-dollar"></i>
                                                </button>
                                                @if (Model.Status == "Open")
                                                {
                                                    <button type="button" class="btn btn-sm btn-outline-primary"
                                                            title="Edit Ticket"
                                                            onclick="openDispatchTicketModal(@ticket.DispatchTicketId)">
                                                        <i class="bi bi-pencil"></i>
                                                    </button>
                                                }
                                            }
                                            else if (ticket.Status == "For Approval")
                                            {
                                                <button type="button" class="btn btn-sm btn-outline-success"
                                                        title="Review & Approve"
                                                        onclick="openApprovalModal(@ticket.DispatchTicketId)">
                                                    <i class="bi bi-check-circle"></i>
                                                </button>
                                            }
                                            else if (ticket.Status == "Disapproved")
                                            {
                                                <button type="button" class="btn btn-sm btn-outline-warning"
                                                        title="Edit Tariff"
                                                        onclick="openEditTariffModal(@ticket.DispatchTicketId)">
                                                    <i class="bi bi-pencil"></i>
                                                </button>
                                            }
                                            else if (ticket.Status == "For Billing" || ticket.Status == "Billed")
                                            {
                                                <a asp-controller="DispatchTicket" asp-action="Preview"
                                                   asp-route-id="@ticket.DispatchTicketId"
                                                   class="btn btn-sm btn-outline-secondary" title="View Details">
                                                    <i class="bi bi-file-earmark-text"></i>
                                                </a>
                                            }
                                        </div>
                                    </td>
                                </tr>
                            }
                            </tbody>
                        </table>
                    </div>
                </div>
            </div>
        </div>

        <!-- Ticket Details Modal -->
        <div class="modal fade" id="ticketModal" tabindex="-1" aria-labelledby="ticketModalLabel" aria-hidden="true">
            <div class="modal-dialog modal-lg">
                <div class="modal-content">
                    <div class="modal-header bg-primary text-white">
                        <h5 class="modal-title" id="ticketModalLabel">Dispatch Ticket Details</h5>
                        <button type="button" class="btn-close btn-close-white" data-bs-dismiss="modal"
                                aria-label="Close"></button>
                    </div>
                    <div class="modal-body" id="ticketModalBody">
                        <div class="text-center py-4">
                            <div class="spinner-border text-info" role="status">
                                <span class="visually-hidden">Loading...</span>
                            </div>
                        </div>
                    </div>
                    <div class="modal-footer">
                        <button type="button" class="btn btn-secondary" data-bs-dismiss="modal">Close</button>
                    </div>
                </div>
            </div>
        </div>

        <!-- Add Ticket Modal -->
        <div class="modal fade" id="addTicketModal" tabindex="-1" aria-labelledby="addTicketModalLabel"
             aria-hidden="true">
            <div class="modal-dialog modal-lg">
                <div class="modal-content">
                    <div class="modal-header bg-primary text-white">
                        <h5 class="modal-title" id="addTicketModalLabel"><i class="bi bi-plus-circle me-2"></i>Add New
                            Dispatch Ticket</h5>
                        <button type="button" class="btn-close btn-close-white" data-bs-dismiss="modal"
                                aria-label="Close"></button>
                    </div>
                    <div class="modal-body" id="addTicketModalBody">
                        <div class="text-center py-4">
                            <div class="spinner-border text-primary" role="status">
                                <span class="visually-hidden">Loading...</span>
                            </div>
                        </div>
                    </div>
                    <div class="modal-footer">
                        <button type="button" class="btn btn-secondary" data-bs-dismiss="modal">Cancel</button>
                        <button type="button" class="btn btn-primary" id="saveTicketBtn"
                                onclick="submitAddTicketForm()"><i class="bi bi-save me-1"></i> Save Ticket
                        </button>
                    </div>
                </div>
            </div>
        </div>

        @section Scripts {
            <script>
                $(document).ready(function () {
                    $('#ticketsTable').DataTable({
                        responsive: true,
                        order: [[0, 'desc']],
                        language: {
                            search: "_INPUT_",
                            searchPlaceholder: "Search Tickets..."
                        }
                    });
                });

                function openDispatchTicketModal(ticketId = null) {
                    const modal = new bootstrap.Modal(document.getElementById('addTicketModal'));
                    const body = document.getElementById('addTicketModalBody');
                    const title = document.getElementById('addTicketModalLabel');
                    const saveBtn = document.getElementById('saveTicketBtn');

                    // Set Title and Button
                    title.innerHTML = ticketId ? '<i class="bi bi-pencil-square me-2"></i>Edit Dispatch Ticket' : '<i class="bi bi-plus-circle me-2"></i>Add New Dispatch Ticket';
                    saveBtn.innerHTML = ticketId ? '<i class="bi bi-check-circle me-1"></i> Update Ticket' : '<i class="bi bi-save me-1"></i> Save Ticket';

                    // Show Loading
                    body.innerHTML = `
                <div class="text-center py-4">
                    <div class="spinner-border text-primary" role="status">
                        <span class="visually-hidden">Loading...</span>
                    </div>
                </div>`;

                    modal.show();

                    // Fetch partial
                    const url = '@Url.Action("GetDispatchTicketPartial", "DispatchTicket")';
                    console.log('Fetching ticket form from:', url);
                    $.get(url, {id: ticketId, jobOrderId: '@Model.JobOrderId'}, function (data) {
                        console.log('✓ Form loaded, length:', data.length);
                        body.innerHTML = data;
                        // Initialize duration calculation after content is fully rendered
                        setTimeout(function () {
                            console.log('Initializing duration calculation...');
                            initializeDurationCalculation();
                        }, 200);
                    }).fail(function (xhr, status, error) {
                        console.error('✗ Failed to load form:', status, error);
                        console.error('Response:', xhr.responseText);
                        Swal.fire({
                            icon: 'error',
                            title: 'Error',
                            text: 'Failed to load ticket form. Please try again.'
                        });
                        body.innerHTML = '<div class="alert alert-danger">Error loading form. Please try again.</div>';
                    });
                }

                function submitAddTicketForm() {
                    var form = $('#dispatchTicketForm');

                    if (form.length === 0) return;

                    // Check form validity using HTML5 validation
                    if (!form[0].checkValidity()) {
                        form[0].reportValidity();
                        return;
                    }

                    // Show loading indicator
                    Swal.fire({
                        title: 'Saving Ticket...',
                        text: 'Please wait',
                        allowOutsideClick: false,
                        didOpen: () => { Swal.showLoading() }
                    });

                    // Let the form submit normally
                    form.submit();
                }

                // Calculate duration between start and end datetime
                function initializeDurationCalculation() {
                    // Wait for elements to exist in DOM - modal uses different IDs
                    const checkExist = setInterval(function () {
                        // Modal uses IDs with 'Modal' prefix (capital M)
                        let dateLeftInput = $('#ModalDateLeft, [name="DateLeft"]');
                        let timeLeftInput = $('#ModalTimeLeft, [name="TimeLeft"]');
                        let dateArrivedInput = $('#ModalDateArrived, [name="DateArrived"]');
                        let timeArrivedInput = $('#ModalTimeArrived, [name="TimeArrived"]');
                        let durationBadge = $('#modalDurationDisplay');
                        let durationDisplay = $('#modalTotalHours');

                        console.log('Checking for elements...', {
                            dateLeft: dateLeftInput.length,
                            timeLeft: timeLeftInput.length,
                            dateArrived: dateArrivedInput.length,
                            timeArrived: timeArrivedInput.length,
                            durationBadge: durationBadge.length,
                            durationDisplay: durationDisplay.length
                        });

                        // Check if all elements exist
                        if (dateLeftInput.length && timeLeftInput.length &&
                            dateArrivedInput.length && timeArrivedInput.length &&
                            durationBadge.length && durationDisplay.length) {

                            clearInterval(checkExist);
                            console.log('✓ Duration calculation initialized');

                            // Listen to changes on all datetime inputs
                            dateLeftInput.add(timeLeftInput).add(dateArrivedInput).add(timeArrivedInput).on('change input', function () {
                                console.log('✓ Datetime input changed, recalculating...');
                                calculateDuration();
                            });

                            // Initial calculation
                            calculateDuration();
                        }
                    }, 100); // Check every 100ms

                    function calculateDuration() {
                        // Modal uses IDs with 'Modal' prefix
                        let dateLeft = $('#ModalDateLeft').val() || $('[name="DateLeft"]').val();
                        let timeLeft = $('#ModalTimeLeft').val() || $('[name="TimeLeft"]').val();
                        let dateArrived = $('#ModalDateArrived').val() || $('[name="DateArrived"]').val();
                        let timeArrived = $('#ModalTimeArrived').val() || $('[name="TimeArrived"]').val();
                        let durationBadge = $('#modalDurationDisplay');
                        let durationDisplay = $('#modalTotalHours');

                        console.log('Calculating duration:', {dateLeft, timeLeft, dateArrived, timeArrived});

                        if (!dateLeft || !timeLeft || !dateArrived || !timeArrived) {
                            durationDisplay.text('0');
                            return;
                        }

                        const startDateTime = new Date(`${dateLeft}T${timeLeft}`);
                        const endDateTime = new Date(`${dateArrived}T${timeArrived}`);

                        if (endDateTime < startDateTime) {
                            durationDisplay.text('Invalid (End before Start)');
                            durationBadge.removeClass('bg-secondary').addClass('bg-danger');
                            console.log('✓ Duration badge updated (invalid)');
                            return;
                        }

                        const diffMs = endDateTime - startDateTime;
                        const diffHrs = (diffMs / 3600000).toFixed(2); // Convert ms to hours

                        console.log('✓ Duration calculated:', diffHrs, 'hours');
                        durationDisplay.text(diffHrs);

                        // Update badge color
                        durationBadge.removeClass('bg-danger').addClass('bg-secondary');
                        console.log('✓ Duration badge updated');
                    }
                }

                function confirmClose() {
                    Swal.fire({
                        title: 'Close Job Order?',
                        text: "Closing this Job Order will prevent adding new tickets to it.",
                        icon: 'warning',
                        showCancelButton: true,
                        confirmButtonColor: '#ffc107',
                        cancelButtonColor: '#6c757d',
                        confirmButtonText: 'Yes, close it!'
                    }).then((result) => {
                        if (result.isConfirmed) {
                            $('#closeForm').submit();
                        }
                    })
                }

                // Check for server-side messages (error/warning/success)
                @if (TempData["error"] != null)
                {
                    <text>
                    Swal.fire({
                        icon: 'error',
                        title: 'Cannot Close Job Order',
                        html: '@TempData["error"]',
                        confirmButtonColor: '#d33'
                    });
                    </text>
                }
                @if (TempData["warning"] != null)
                {
                    <text>
                    Swal.fire({
                        icon: 'warning',
                        title: 'Warning',
                        html: '@Html.Raw(TempData["warning"])',
                        showCancelButton: true,
                        confirmButtonColor: '#ffc107',
                        cancelButtonColor: '#6c757d',
                        confirmButtonText: 'Yes, close anyway',
                        cancelButtonText: 'Cancel'
                    }).then((result) => {
                        if (result.isConfirmed) {
                            $('#confirmCloseValue').val('true');
                            $('#closeForm').submit();
                        }
                    });
                    </text>
                }
                @if (TempData["success"] != null)
                {
                    <text>
                    Swal.fire({
                        icon: 'success',
                        title: 'Success',
                        text: '@TempData["success"]',
                        timer: 3000,
                        showConfirmButton: false
                    });
                    </text>
                }

                function showTicketModal(id) {
                    const modal = new bootstrap.Modal(document.getElementById('ticketModal'));
                    const body = document.getElementById('ticketModalBody');

                    body.innerHTML = `
                <div class="text-center py-4">
                    <div class="spinner-border text-info" role="status">
                        <span class="visually-hidden">Loading...</span>
                    </div>
                </div>`;

                    modal.show();

                    fetch(`@Url.Action("GetTicketDetails", "JobOrder")/${id}`)
                        .then(response => response.json())
                        .then(data => {
                            body.innerHTML = `
                        <div class="row g-3">
                            <div class="col-md-6">
                                <label class="text-muted d-block">Dispatch #</label>
                                <span class="fw-bold">${data.dispatchNumber}</span>
                            </div>
                            <div class="col-md-6">
                                <label class="text-muted d-block">Date</label>
                                <span class="fw-bold">${data.date}</span>
                            </div>
                            <div class="col-md-6">
                                <label class="text-muted d-block">Service</label>
                                <span>${data.serviceName}</span>
                            </div>
                            <div class="col-md-6">
                                <label class="text-muted d-block">Tugboat</label>
                                <span>${data.tugboatName}</span>
                            </div>
                            <div class="col-md-6">
                                <label class="text-muted d-block">Tug Master</label>
                                <span>${data.tugMasterName}</span>
                            </div>
                            <div class="col-md-6">
                                <label class="text-muted d-block">Location</label>
                                <span>${data.location}</span>
                            </div>
                            <div class="col-md-6">
                                <label class="text-muted d-block">Time Start</label>
                                <span>${data.timeStart}</span>
                            </div>
                            <div class="col-md-6">
                                <label class="text-muted d-block">Time End</label>
                                <span>${data.timeEnd}</span>
                            </div>
                            <div class="col-12">
                                <label class="text-muted d-block">Remarks</label>
                                <p class="mb-0 fst-italic">${data.remarks}</p>
                            </div>
                            <div class="col-12">
                                <hr>
                                <label class="text-muted d-block">Status</label>
                                <span class="badge rounded-pill bg-info text-dark">${data.status}</span>
                            </div>
                        </div>
                    `;
                        })
                        .catch(error => {
                            body.innerHTML = `<div class="alert alert-danger">Error loading ticket details: ${error}</div>`;
                        });
                }

                // Tariff Modal Functions
                function openSetTariffModal(ticketId) {
                    const modal = new bootstrap.Modal(document.getElementById('setTariffModal'));
                    const body = document.getElementById('setTariffModalBody');

                    body.innerHTML = `
                <div class="text-center py-4">
                    <div class="spinner-border text-primary" role="status">
                        <span class="visually-hidden">Loading...</span>
                    </div>
                </div>`;

                    modal.show();

                    $.get('@Url.Action("SetTariffModal", "DispatchTicket")', {id: ticketId}, function (data) {
                        body.innerHTML = data;
                        // Initialize calculation after content loads
                        setTimeout(function () {
                            initializeTariffCalculation();
                        }, 100);
                    }).fail(function (xhr, status, error) {
                        console.error('Error loading tariff modal:', status, error);
                        Swal.fire({
                            icon: 'error',
                            title: 'Error',
                            html: '<strong>Failed to load tariff form</strong><br>Please check your permissions and try again.'
                        });
                        modal.hide();
                    });
                }

                function openEditTariffModal(ticketId) {
                    const modal = new bootstrap.Modal(document.getElementById('editTariffModal'));
                    const body = document.getElementById('editTariffModalBody');

                    body.innerHTML = `
                <div class="text-center py-4">
                    <div class="spinner-border text-warning" role="status">
                        <span class="visually-hidden">Loading...</span>
                    </div>
                </div>`;

                    modal.show();

                    $.get('@Url.Action("EditTariffModal", "DispatchTicket")', {id: ticketId}, function (data) {
                        body.innerHTML = data;
                        // Initialize calculation after content loads
                        setTimeout(function () {
                            initializeTariffCalculation();
                        }, 100);
                    }).fail(function (xhr, status, error) {
                        console.error('Error loading edit tariff modal:', status, error);
                        Swal.fire({
                            icon: 'error',
                            title: 'Error',
                            html: '<strong>Failed to load tariff form</strong><br>Please check your permissions and try again.'
                        });
                        modal.hide();
                    });
                }

                function openApprovalModal(ticketId) {
                    const modal = new bootstrap.Modal(document.getElementById('tariffApprovalModal'));
                    const body = document.getElementById('tariffApprovalModalBody');

                    body.innerHTML = `
                <div class="text-center py-4">
                    <div class="spinner-border text-info" role="status">
                        <span class="visually-hidden">Loading...</span>
                    </div>
                </div>`;

                    modal.show();

                    $.get('@Url.Action("TariffApprovalModal", "DispatchTicket")', {id: ticketId}, function (data) {
                        body.innerHTML = data;
                    }).fail(function (xhr, status, error) {
                        console.error('Error loading approval modal:', status, error);
                        Swal.fire({
                            icon: 'error',
                            title: 'Error',
                            html: '<strong>Failed to load tariff details</strong><br>Please check your permissions and try again.'
                        });
                        modal.hide();
                    });
                }

                function approveTariff(ticketId) {
                    Swal.fire({
                        title: 'Approve Tariff?',
                        text: "This will move the ticket to 'For Billing' status.",
                        icon: 'question',
                        showCancelButton: true,
                        confirmButtonColor: '#28a745',
                        cancelButtonColor: '#6c757d',
                        confirmButtonText: 'Yes, approve it!',
                        cancelButtonText: 'Cancel'
                    }).then((result) => {
                        if (result.isConfirmed) {
                            // Show loading
                            Swal.fire({
                                title: 'Approving...',
                                allowOutsideClick: false,
                                didOpen: () => { Swal.showLoading() }
                            });

                            $.post('@Url.Action("ApproveTariff", "DispatchTicket")', {id: ticketId}, function (response) {
                                if (response.success) {
                                    Swal.fire({
                                        icon: 'success',
                                        title: 'Approved!',
                                        text: 'Tariff approved successfully.',
                                        timer: 2000,
                                        showConfirmButton: false
                                    }).then(() => {
                                        bootstrap.Modal.getInstance(document.getElementById('tariffApprovalModal')).hide();
                                        location.reload();
                                    });
                                } else {
