@model CreateBillingViewModel

@{
    ViewData["Title"] = "Billing - Edit";
}

<style>
    .container {
        max-width: 100% !important;
        width: 100% !important;
    }

    .section-header {
        font-size: 1rem;
        font-weight: 600;
        margin-top: 1.5rem;
        margin-bottom: 1rem;
        padding-bottom: 0.5rem;
    }

    /* Custom styles for professional look */
    .table th {
        font-weight: 600;
        color: #374151;
        text-transform: uppercase;
        font-size: 0.75rem;
        letter-spacing: 0.025em;
    }

    .table tbody tr {
        transition: all 0.2s;
    }

    .table tbody tr:hover {
        background-color: rgba(59, 130, 246, 0.05);
    }

    .totals-box {
        background-color: #f8f9fa;
        border-radius: 0.5rem;
        padding: 1rem;
        border: 1px solid #dee2e6;
    }

    #PrincipalSearchResults, #JobOrderSearchResults {
        z-index: 1050;
        max-height: 200px;
        overflow-y: auto;
    }
</style>

<link rel="stylesheet" href="~/css/form-style.css">

<div class="card shadow mt-4">
    <div class="card-header bg-secondary bg-gradient ml-0 py-3">
        <div class="col-12 text-center">
            <h2 class="text-white py-2">@ViewData["Title"] #@Model.MMSIBillingNumber</h2>
        </div>
    </div>

    <div class="card-body p-4">
        <form id="myForm" method="post">
            @Html.AntiForgeryToken()
            <input asp-for="MMSIBillingId" id="billingId" value="@Model.MMSIBillingId" type="hidden">
            <input type="hidden" asp-for="IsUndocumented" value="@Model.IsUndocumented" />

            <div class="border-2 px-3">
                <div asp-validation-summary="ModelOnly" class="text-danger mb-3"></div>

                <!-- I. Customer (Read-only during edit) -->
                <div class="mb-4">
                    <h5 class="section-header text-secondary border-bottom"><i class="bi bi-person-check me-2"></i>I. Customer Details</h5>
                    <div class="row">
                        <div class="col-md-12">
                            <label class="form-label fw-bold">Customer</label>
                            <div class="input-group">
                                <span class="input-group-text bg-light border-0 shadow-sm"><i class="bi bi-person text-muted"></i></span>
                                <input type="text" class="form-control bg-light border-0 shadow-sm" value="@(Model.Customers?.FirstOrDefault(c => c.Value == Model.CustomerId.ToString())?.Text ?? "")" readonly>
                                <input type="hidden" asp-for="CustomerId" id="CustomerId" value="@Model.CustomerId" />
                                <div class="input-group-text @(ViewData["HasPrincipal"] as bool? == true ? "" : "d-none") bg-light border-0 shadow-sm" id="PrincipalCheckboxContainer">
                                    <input class="form-check-input mt-0 me-1" type="checkbox" id="UsePrincipalCheckbox" @(Model.PrincipalId.HasValue ? "checked" : "")>
                                    <label class="small mb-0" for="UsePrincipalCheckbox">Bill to Principal</label>
                                </div>
                            </div>
                        </div>
                    </div>
                </div>

                <!-- Customer Details Display -->
                <div id="CustomerDetailsSection" class="mb-4">
                    <div class="card border-0 bg-light shadow-sm">
                        <div class="card-body py-3">
                            <div class="row g-3 small">
                                <div class="col-md-6">
                                    <span class="text-muted text-uppercase fw-bold" style="font-size: 0.7rem;">Address:</span><br>
                                    <span id="CustomerAddress" class="fw-semibold">@(ViewData["CustomerAddress"] ?? "-")</span>
                                </div>
                                <div class="col-md-3">
                                    <span class="text-muted text-uppercase fw-bold" style="font-size: 0.7rem;">TIN:</span><br>
                                    <span id="CustomerTIN" class="fw-semibold">@(ViewData["CustomerTIN"] ?? "-")</span>
                                </div>
                                <div class="col-md-3">
                                    <span class="text-muted text-uppercase fw-bold" style="font-size: 0.7rem;">Terms:</span><br>
                                    <span id="CustomerTerms" class="fw-semibold">@(ViewData["CustomerTerms"] ?? "-")</span>
                                </div>
                                <div class="col-md-6">
                                    <span class="text-muted text-uppercase fw-bold" style="font-size: 0.7rem;">Business Style:</span><br>
                                    <span id="CustomerBusinessStyle" class="fw-semibold">@(ViewData["CustomerBusinessStyle"] ?? "-")</span>
                                </div>
                                <div class="col-md-3">
                                    <span class="text-muted text-uppercase fw-bold" style="font-size: 0.7rem;">VAT Type:</span><br>
                                    <span id="CustomerVatType" class="fw-semibold">@(ViewData["CustomerVatType"] ?? "-")</span>
                                </div>
                                <div class="col-md-3">
                                    <span class="text-muted text-uppercase fw-bold" style="font-size: 0.7rem;">Type:</span><br>
                                    <span id="CustomerType" class="fw-semibold">@(ViewData["CustomerType"] ?? "-")</span>
                                </div>
                            </div>
                        </div>
                    </div>
                </div>

                <!-- Principal Section (Inline) -->
                <div class="row g-3 mb-4 @(Model.PrincipalId.HasValue ? "" : "d-none")" id="PrincipalSection">
                    <div class="col-md-8 position-relative">
                        <label class="form-label fw-bold small text-secondary">Principal</label>
                        <div class="input-group">
                            <span class="input-group-text bg-white border-0 shadow-sm"><i class="bi bi-search text-muted"></i></span>
                            <input type="text" id="PrincipalSearch" class="form-control border-0 shadow-sm" placeholder="Search principals..." value="@(Model.CustomerPrincipal?.FirstOrDefault(p => p.Value == Model.PrincipalId?.ToString())?.Text ?? "")" autocomplete="off">
                            <input type="hidden" asp-for="PrincipalId" id="PrincipalId" value="@Model.PrincipalId" />
                        </div>
                        <div id="PrincipalSearchResults" class="list-group position-absolute w-100 shadow d-none"></div>
                    </div>
                    <div class="col-md-4 d-flex align-items-end">
                        <div class="@(Model.PrincipalId.HasValue ? "" : "d-none") w-100" id="BilledToContainer">
                            <label class="form-label fw-bold small text-secondary d-block">Billed To</label>
                            <div class="btn-group w-100 shadow-sm" role="group">
                                <input type="radio" class="btn-check" asp-for="BilledTo" value="LOCAL" id="billLocal" autocomplete="off">
                                <label class="btn btn-outline-primary" for="billLocal">Local</label>
                                <input type="radio" class="btn-check" asp-for="BilledTo" value="PRINCIPAL" id="billPrincipal" autocomplete="off">
                                <label class="btn btn-outline-primary" for="billPrincipal">Principal</label>
                            </div>
                        </div>
                    </div>
                </div>

                <!-- Two Column Layout for Operation Details and Tickets -->
                <div class="row g-4">
                    <!-- Left Column: Operation Configuration -->
                    <div class="col-12 col-xl-4">
                        <div class="card h-100 border-0 bg-light shadow-sm">
                            <div class="card-header bg-white border-0 py-3">
                                <h6 class="mb-0 fw-bold text-secondary"><i class="bi bi-gear-fill me-2"></i>Operation Details</h6>
                            </div>
                            <div class="card-body pt-0">
                                <div class="row g-3">
                                    <div class="col-12">
                                        <label asp-for="MMSIBillingNumber" class="form-label fw-bold small">Billing Number</label>
                                        <input asp-for="MMSIBillingNumber" type="text" class="form-control border-0 shadow-sm bg-light" readonly>
                                    </div>
                                    <div class="col-12 col-md-6">
                                        <label asp-for="VoyageNumber" class="form-label fw-bold small">Voyage Number <span class="text-danger">*</span></label>
                                        <input asp-for="VoyageNumber" type="text" class="form-control border-0 shadow-sm" id="VoyageNumber" required>
                                    </div>
                                    <div class="col-12 col-md-6">
                                        <label asp-for="Date" class="form-label fw-bold small">Date Created</label>
                                        <input asp-for="Date" type="date" class="form-control border-0 shadow-sm" value="@Model.Date.ToString("yyyy-MM-dd")">
                                    </div>
                                    <div class="col-12">
                                        <label asp-for="PortId" class="form-label fw-bold small">Port <span class="text-danger">*</span></label>
                                        <select asp-for="PortId" asp-items="@Model.Ports" id="PortSelect" class="form-select js-select2 border-0 shadow-sm" required style="width: 100%;">
                                            <option value="">-- Select Port --</option>
                                        </select>
                                    </div>
                                    <div class="col-12">
                                        <label asp-for="TerminalId" class="form-label fw-bold small">Terminal <span class="text-danger">*</span></label>
                                        <select asp-for="TerminalId" asp-items="@Model.Terminals" id="TerminalSelect" class="form-select js-select2 border-0 shadow-sm" required style="width: 100%;">
                                            <option value="">-- Select Terminal --</option>
                                        </select>
                                    </div>
                                    <div class="col-12">
                                        <label asp-for="VesselId" class="form-label fw-bold small">Vessel <span class="text-danger">*</span></label>
                                        <select asp-for="VesselId" asp-items="@Model.Vessels" class="form-select js-select2 border-0 shadow-sm" required style="width: 100%;">
                                            <option value="">-- Select Vessel --</option>
                                        </select>
                                    </div>
                                    <div class="col-12">
                                        <label asp-for="ApOtherTug" class="form-label fw-bold small">AP Other Tug</label>
                                        <input asp-for="ApOtherTug" step="0.01" type="number" class="form-control border-0 shadow-sm" min="0" placeholder="0.00">
                                    </div>
                                </div>
                            </div>
                        </div>
                    </div>

                    <!-- Right Column: Job Order & Ticket Selection -->
                    <div class="col-12 col-xl-8">
                        <div class="card h-100 border-0 shadow-sm">
                            <div class="card-header bg-white border-0 py-3 d-flex justify-content-between align-items-center">
                                <h6 class="mb-0 fw-bold text-secondary"><i class="bi bi-briefcase me-2"></i>Job Order & Dispatch Tickets</h6>
                                <span class="badge bg-info shadow-sm" id="selectedTicketCount">0 selected</span>
                            </div>
                            <div class="card-body pt-0">
                                <!-- Job Order Search -->
                                <div class="mb-4">
                                    <label class="form-label fw-bold small text-muted">Select Job Order</label>
                                    <div class="position-relative">
                                        <div class="input-group">
                                            <span class="input-group-text bg-white border-0 shadow-sm"><i class="bi bi-hash text-muted"></i></span>
                                            <input type="text" id="JobOrderSearch" class="form-control border-0 shadow-sm" placeholder="Search job order number..." autocomplete="off">
                                        </div>
                                        <input type="hidden" asp-for="JobOrderId" id="JobOrderId" />
                                        <div id="JobOrderSearchResults" class="list-group position-absolute w-100 shadow d-none"></div>
                                    </div>
                                    <small class="text-muted ps-1">Tickets are filtered by Job Order</small>
                                </div>

                                <!-- Tickets Table -->
                                <div class="table-responsive border rounded" style="max-height: 400px;">
                                    <table id="ticketsTable" class="table table-hover mb-0">
                                        <thead class="table-light">
                                            <tr>
                                                <th class="text-center" style="width: 40px;">
                                                    <input type="checkbox" id="selectAllTickets" class="form-check-input">
                                                </th>
                                                <th class="text-center">Dispatch#</th>
                                                <th class="text-center">Tugboat</th>
                                                <th class="text-center">Service</th>
                                                <th class="text-center">Hours</th>
                                                <th class="text-end pe-3">Amount</th>
                                            </tr>
                                        </thead>
                                        <tbody>
                                            <tr class="text-muted">
                                                <td colspan="6" class="text-center py-4">
                                                    <i class="bi bi-info-circle me-2"></i>Load a job order to view available tickets
                                                </td>
                                            </tr>
                                        </tbody>
                                    </table>
                                </div>

                                <!-- Hidden select for form submission -->
                                <select asp-for="ToBillDispatchTickets" id="DispatchTicketSelect" name="ToBillDispatchTickets" multiple="multiple" class="d-none">
                                    @if (Model.ToBillDispatchTickets != null)
                                    {
                                        foreach (var ticketId in Model.ToBillDispatchTickets)
                                        {
                                            <option value="@ticketId" selected="selected">@ticketId</option>
                                        }
                                    }
                                </select>

                                <!-- Totals Display -->
                                <div class="totals-box mt-4 shadow-sm border-0">
                                    <div class="row text-center">
                                        <div class="col-4">
                                            <span class="text-muted text-uppercase fw-bold" style="font-size: 0.75rem;">Total Dispatch</span><br>
                                            <strong class="text-primary fs-5">₱<span id="DispatchAmountTotal">0.00</span></strong>
                                        </div>
                                        <div class="col-4 border-start">
                                            <span class="text-muted text-uppercase fw-bold" style="font-size: 0.75rem;">Total BAF</span><br>
                                            <strong class="text-primary fs-5">₱<span id="BAFAmountTotal">0.00</span></strong>
                                        </div>
                                        <div class="col-4 border-start">
                                            <span class="text-muted text-uppercase fw-bold" style="font-size: 0.75rem;">Overall Total</span><br>
                                            <strong class="text-success fs-4">₱<span id="OverallTotal">0.00</span></strong>
                                        </div>
                                    </div>
                                </div>
                            </div>
                        </div>
                    </div>
                </div>

                <!-- Form Actions -->
                <div class="row mt-5 mb-3 justify-content-end gap-2">
                    <div class="col-auto">
                        <a class="btn btn-outline-secondary shadow-sm px-4" asp-controller="Billing" asp-action="Index">
                            <i class="bi bi-arrow-left-circle me-2"></i>Cancel & Back
                        </a>
                    </div>
                    <div class="col-auto">
                        <button class="btn btn-primary bg-gradient shadow-sm px-5" type="submit" id="submitButton">
                            <i class="bi bi-save-fill me-2"></i>Save Changes
                        </button>
                    </div>
                </div>
            </div>
        </form>
    </div>
</div>

@section Scripts {
    <script>
        $(document).ready(function () {
            // Initialize Select2
            $('.js-select2').select2({
                placeholder: "-- Select --",
                allowClear: true
            });

            const currentCustomerId = $("#CustomerId").val();
            const billingId = $("#billingId").val();
            setupEventListeners();
            fillDataOnStartup();

            function setupEventListeners() {
                $("#UsePrincipalCheckbox").on("change", handleUsePrincipalChange);
                $("#PortSelect").on("change", handlePortChange);
                $("#submitButton").on("click", areYouSureToBill);
            }

            async function fillDataOnStartup() {
                // Initialize "Billed To" radio
                const initialBilledTo = '@Model.BilledTo';
                if (initialBilledTo === 'PRINCIPAL') $("#billPrincipal").prop("checked", true);
                else $("#billLocal").prop("checked", true);

                // Load already billed tickets into the table
                if (currentCustomerId && billingId) {
                    try {
                        const res = await fetch('@Url.Action("GetDispatchTickets", "Billing", new { area = "User" })', {
                            method: 'POST',
                            headers: { 'Content-Type': 'application/x-www-form-urlencoded' },
                            body: `dispatchTicketIds=${$("#DispatchTicketSelect").val().join('&dispatchTicketIds=')}`
                        });
                        const data = await res.json();
                        renderTicketsTable(data.data.map(t => ({
                            dispatchTicketId: t.dispatchTicketId,
                            dispatchNo: t.dispatchNumber,
                            tugboat: t.tugboat?.tugboatName || 'N/A',
                            service: t.service?.serviceName || 'N/A',
                            duration: t.totalHours,
                            totalAmount: t.totalNetRevenue
                        })));
                    } catch (e) { console.error('Error loading initial tickets', e); }
                }
            }

            function handleUsePrincipalChange() {
                const isChecked = $("#UsePrincipalCheckbox").is(":checked");
                if (isChecked) {
                    $("#PrincipalSection").removeClass("d-none");
                    $("#BilledToContainer").removeClass("d-none");
                    setTimeout(() => $("#PrincipalSearch").focus(), 100);
                } else {
                    $("#PrincipalSection").addClass("d-none");
                    $("#PrincipalSearch").val("");
                    $("#PrincipalId").val("");
                    $("#BilledToContainer").addClass("d-none");
                    $("#billLocal").prop("checked", true);
                }
            }

            // ── Principal search ─────────────────────────────────────────────
            let principalSearchTimeout;
            const $principalSearch = $("#PrincipalSearch");
            const $principalResults = $("#PrincipalSearchResults");
            const $principalId = $("#PrincipalId");

            async function performPrincipalSearch(searchTerm) {
                if (!currentCustomerId) return;
                try {
                    const params = new URLSearchParams({ customerId: currentCustomerId });
                    params.set('term', searchTerm);
                    const res = await fetch(`@Url.Action("SearchPrincipals", "Billing", new { area = "User" })?${params}`);
                    const data = await res.json();
                    $principalResults.empty();
                    if (Array.isArray(data) && data.length > 0) {
                        data.forEach(item => {
                            $principalResults.append(
                                $('<a href="#" class="list-group-item list-group-item-action py-2">')
                                    .data('principal', item)
                                    .html(`<span>${item.name}</span>`)
                            );
                        });
                    } else {
                        $principalResults.append($('<div class="list-group-item py-2 text-muted"><em>No principals found</em></div>'));
                    }
                    $principalResults.removeClass('d-none');
                } catch {
                    $principalResults.empty().addClass('d-none');
                }
            }

            $principalSearch.on('input', function () {
                clearTimeout(principalSearchTimeout);
                const searchTerm = $(this).val().trim();
                if (searchTerm.length === 0) $principalId.val('');
                principalSearchTimeout = setTimeout(() => performPrincipalSearch(searchTerm), 150);
            });

            $principalSearch.on('focus', function () {
                performPrincipalSearch($(this).val().trim());
            });

            $principalResults.on('click', 'a', function (e) {
                e.preventDefault();
                const principal = $(this).data('principal');
                $principalSearch.val(principal.name);
                $principalId.val(principal.value);
                $principalResults.empty().addClass('d-none');

                fetch('@Url.Action("GetPrincipalDetails", "Billing", new { area = "User" })?principalId=' + principal.value)
                    .then(r => r.json())
                    .then(data => {
                        $("#CustomerAddress").text(data.address || '-');
                        $("#CustomerTIN").text(data.tinNo || '-');
                        $("#CustomerTerms").text(data.terms || '-');
                        $("#CustomerBusinessStyle").text(data.businessStyle || '-');
                    });
            });

            // ── Job Order search ─────────────────────────────────────────────
            let jobOrderSearchTimeout;
            const $jobOrderSearch = $("#JobOrderSearch");
            const $jobOrderResults = $("#JobOrderSearchResults");
            const $jobOrderId = $("#JobOrderId");
            const $ticketsTableBody = $("#ticketsTable tbody");
            const $dispatchSelect = $("#DispatchTicketSelect");

            async function performJobOrderSearch(searchTerm) {
                if (!currentCustomerId) return;
                try {
                    const res = await fetch(`@Url.Action("SearchJobOrders", "Billing", new { area = "User" })?customerId=${encodeURIComponent(currentCustomerId)}&term=${encodeURIComponent(searchTerm)}`);
                    const data = await res.json();
                    $jobOrderResults.empty();
                    if (Array.isArray(data) && data.length > 0) {
                        data.forEach(item => {
                            $jobOrderResults.append(
                                $('<a href="#" class="list-group-item list-group-item-action py-2">')
                                    .data('jobOrder', item)
                                    .html(`<strong>${item.name}</strong><br><small class="text-muted">${item.description || ''}</small>`)
                            );
                        });
                    } else {
                        $jobOrderResults.append($('<div class="list-group-item py-2 text-muted"><em>No job orders found</em></div>'));
                    }
                    $jobOrderResults.removeClass('d-none');
                } catch {
                    $jobOrderResults.empty().addClass('d-none');
                }
            }

            $jobOrderSearch.on('input', function () {
                clearTimeout(jobOrderSearchTimeout);
                const searchTerm = $(this).val().trim();
                jobOrderSearchTimeout = setTimeout(() => performJobOrderSearch(searchTerm), 150);
            });

            $jobOrderSearch.on('focus click', function () {
                performJobOrderSearch($(this).val().trim());
            });

            $jobOrderResults.on('click', 'a', async function (e) {
                e.preventDefault();
                const jobOrder = $(this).data('jobOrder');
                $jobOrderSearch.val(jobOrder.name);
                $jobOrderId.val(jobOrder.value);
                $jobOrderResults.empty().addClass('d-none');
                try {
                    const res = await fetch(`@Url.Action("GetDispatchTicketsByJobOrder", "Billing", new { area = "User" })?jobOrderId=${encodeURIComponent(jobOrder.value)}`);
                    const tickets = await res.json();

                    // Merge with existing tickets in the table
                    let existingIds = [];
                    $ticketsTableBody.find('tr[data-ticket-id]').each(function() {
                        existingIds.push($(this).data('ticket-id').toString());
                    });

                    tickets.forEach(ticket => {
                        if (!existingIds.includes(ticket.dispatchTicketId.toString())) {
                            $ticketsTableBody.append(`
                                <tr data-ticket-id="${ticket.dispatchTicketId}">
                                    <td class="text-center"><input type="checkbox" class="form-check-input ticket-checkbox" value="${ticket.dispatchTicketId}" checked></td>
                                    <td class="text-center fw-bold">${ticket.dispatchNo}</td>
                                    <td class="text-center">${ticket.tugboat}</td>
                                    <td class="text-center">${ticket.service}</td>
                                    <td class="text-center">${ticket.duration.toFixed(2)}</td>
                                    <td class="text-end pe-3">₱${formatNumber(ticket.totalAmount)}</td>
                                </tr>
                            `);
                            if (!$dispatchSelect.find(`option[value="${ticket.dispatchTicketId}"]`).length) {
                                $dispatchSelect.append($('<option>').val(ticket.dispatchTicketId).text(ticket.dispatchNo).prop('selected', true));
                            }
                        }
                    });
                    updateTotals();
                } catch {
                    Swal.fire('Error', 'Failed to load tickets', 'error');
                }
            });

            function renderTicketsTable(tickets) {
                $ticketsTableBody.empty();
                if (!tickets?.length) {
                    $ticketsTableBody.html('<tr class="text-muted"><td colspan="6" class="text-center py-4"><em>No tickets available</em></td></tr>');
                    updateTotals();
                    return;
                }
                tickets.forEach(ticket => {
                    $ticketsTableBody.append(`
                        <tr data-ticket-id="${ticket.dispatchTicketId}">
                            <td class="text-center"><input type="checkbox" class="form-check-input ticket-checkbox" value="${ticket.dispatchTicketId}" checked></td>
                            <td class="text-center fw-bold">${ticket.dispatchNo}</td>
                            <td class="text-center">${ticket.tugboat}</td>
                            <td class="text-center">${ticket.service}</td>
                            <td class="text-center">${ticket.duration.toFixed(2)}</td>
                            <td class="text-end pe-3">₱${formatNumber(ticket.totalAmount)}</td>
                        </tr>
                    `);
                });
                updateTotals();
            }

            $ticketsTableBody.on('change', '.ticket-checkbox', function () {
                const ticketId = $(this).val();
                const $option = $dispatchSelect.find(`option[value="${ticketId}"]`);
                if ($(this).is(':checked')) {
                    if (!$option.length) $dispatchSelect.append($('<option>').val(ticketId).prop('selected', true));
                    else $option.prop('selected', true);
                } else {
                    $option.prop('selected', false);
                }
                updateTotals();
            });

            $('#selectAllTickets').on('change', function () {
                $ticketsTableBody.find('.ticket-checkbox').prop('checked', $(this).is(':checked')).trigger('change');
            });

            function updateTotals() {
                let dispatch = 0, baf = 0;
                $ticketsTableBody.find('.ticket-checkbox:checked').each(function () {
                    const total = parseFloat($(this).closest('tr').find('td:eq(5)').text().replace(/[^0-9.-]+/g, '')) || 0;
                    dispatch += total * 0.8;
                    baf += total * 0.2;
                });
                const count = $ticketsTableBody.find('.ticket-checkbox:checked').length;
                $('#DispatchAmountTotal').text(formatNumber(dispatch));
                $('#BAFAmountTotal').text(formatNumber(baf));
                $('#OverallTotal').text(formatNumber(dispatch + baf));
                $('#selectedTicketCount').text(`${count} selected`);
            }

            // ── Global click ────────────────────────────────────────────────
            $(document).on('click', function (e) {
                if (!$(e.target).closest('#PrincipalSearch, #PrincipalSearchResults, #JobOrderSearch, #JobOrderSearchResults').length) {
                    $principalResults.addClass('d-none');
                    $jobOrderResults.addClass('d-none');
                }
            });

            // ── Port → Terminal cascade ──────────────────────────────────────
            async function handlePortChange() {
                try {
                    const res = await fetch(`@Url.Action("ChangeTerminal", "DispatchTicket", new { area = "User" })?portId=${encodeURIComponent($("#PortSelect").val())}`);
                    const data = await res.json();
                    const $terminalSelect = $("#TerminalSelect");
                    $terminalSelect.empty().append('<option value="">Select Terminal</option>');
                    if (Array.isArray(data)) data.forEach(item => $terminalSelect.append($('<option>').val(item.value).text(item.text)));
                } catch {
                    console.error('Failed to load terminals');
                }
            }

            // ── Submit ───────────────────────────────────────────────────────
            function areYouSureToBill(event) {
                event.preventDefault();
                const form = document.getElementById("myForm");
                if (!form.checkValidity()) { form.reportValidity(); return; }
                if (!$("#DispatchTicketSelect").val()?.length) {
                    Swal.fire({ title: "No Tickets Selected", text: "Please select at least one dispatch ticket to bill.", icon: "warning" });
                    return;
                }
                Swal.fire({ title: "Save changes?", text: "Proceed with updating this billing?", icon: "question", showCancelButton: true, confirmButtonText: "Yes, save" })
                    .then(result => { if (result.isConfirmed) submitEditForm(); });
            }

            async function submitEditForm() {
                try {
                    const res = await fetch('@Url.Action("Edit", "Billing", new { area = "User" })', {
                        method: 'POST',
                        headers: { 'Content-Type': 'application/x-www-form-urlencoded' },
                        body: new URLSearchParams(new FormData(document.getElementById('myForm'))).toString()
                    });
                    const response = await res.json();
                    if (response.success) {
                        Swal.fire({ title: "Success!", text: response.message, icon: "success" })
                            .then(() => response.redirectUrl ? window.location.href = response.redirectUrl : location.reload());
                    } else {
                        Swal.fire({ title: "Error", text: response.message || "Failed to update billing.", icon: "error" });
                    }
                } catch {
                    Swal.fire({ title: "Error", text: "An error occurred while updating the billing.", icon: "error" });
                }
            }
        });
    </script>
}
