@model CreateBillingViewModel

<style>
    #billingModal .modal-dialog {
        max-width: 95% !important;
        width: 95% !important;
    }
    #billingModal .modal-content {
        min-height: 85vh;
    }
</style>

<div class="modal-header bg-secondary">
    <h5 class="modal-title text-white">Create Billing</h5>
    <button type="button" class="btn-close btn-close-white" data-bs-dismiss="modal" aria-label="Close"></button>
</div>

<form id="billingCreateForm" method="post">
    @Html.AntiForgeryToken()
    <div class="modal-body p-4">
        <div asp-validation-summary="ModelOnly" class="text-danger mb-3"></div>
        
        <!-- Customer Selection (Full Width) -->
        <div class="mb-3 position-relative">
            <label asp-for="CustomerId" class="form-label fw-bold">Customer <span class="text-danger">*</span></label>
            <div class="input-group">
                <span class="input-group-text bg-white"><i class="bi bi-search text-muted"></i></span>
                <input type="text" id="CustomerSearch" class="form-control" placeholder="Type to search customers..." autocomplete="off">
                <input type="hidden" asp-for="CustomerId" id="CustomerId" />
                <div class="input-group-text d-none bg-white" id="PrincipalCheckboxContainer">
                    <input class="form-check-input mt-0 me-1" type="checkbox" id="UsePrincipalCheckbox">
                    <label class="small mb-0" for="UsePrincipalCheckbox" style="white-space: nowrap;">Bill to Principal</label>
                </div>
            </div>
            <div id="CustomerSearchResults" class="list-group position-absolute w-100 shadow-sm border" style="z-index: 1050; max-height: 200px; overflow-y: auto; top: 100%;"></div>
            <span asp-validation-for="CustomerId" class="text-danger small"></span>
        </div>

        <!-- Principal Section (Inline) -->
        <div class="row g-3 mb-3 d-none" id="PrincipalSection">
            <div class="col-md-7 position-relative">
                <label class="form-label fw-bold small">Principal</label>
                <div class="input-group">
                    <span class="input-group-text bg-white"><i class="bi bi-search text-muted"></i></span>
                    <input type="text" id="PrincipalSearch" class="form-control" placeholder="Type to search principals..." autocomplete="off">
                    <input type="hidden" asp-for="PrincipalId" id="PrincipalId" />
                </div>
                <div id="PrincipalSearchResults" class="list-group position-absolute w-100 shadow-sm border" style="z-index: 1050; max-height: 200px; overflow-y: auto; top: 100%;"></div>
            </div>
            <div class="col-md-5 d-flex align-items-end">
                <div class="d-none" id="BilledToContainer">
                    <label class="form-label fw-bold small d-block">Billed To</label>
                    <div class="form-check form-check-inline">
                        <input asp-for="BilledTo" class="form-check-input" value="LOCAL" type="radio" id="billLocal" checked>
                        <label class="form-check-label small" for="billLocal">Local</label>
                    </div>
                    <div class="form-check form-check-inline">
                        <input asp-for="BilledTo" class="form-check-input" value="PRINCIPAL" type="radio" id="billPrincipal">
                        <label class="form-check-label small" for="billPrincipal">Principal</label>
                    </div>
                </div>
            </div>
        </div>

        <!-- Two Column Layout -->
        <div class="row g-3">
            <!-- Left Column: Billing Configuration -->
            <div class="col-12 col-lg-4">
                <div class="card h-100 border-0 bg-light">
                    <div class="card-header bg-transparent border-0 py-2">
                        <h6 class="mb-0 fw-bold text-secondary"><i class="bi bi-receipt me-2"></i>Billing Details</h6>
                    </div>
                    <div class="card-body pt-0">
                        <div class="row g-3">
                            <div class="col-12">
                                <label asp-for="MMSIBillingNumber" class="form-label fw-bold">Billing Number <span class="text-danger" id="billingNumberRequired">*</span></label>
                                <div class="input-group">
                                    <input asp-for="MMSIBillingNumber" type="text" class="form-control" id="billingNumber" placeholder="BL-XXXX-XXXXXX">
                                    <div class="input-group-text">
                                        <input type="hidden" asp-for="IsUndocumented" />
                                        <input class="form-check-input mt-0" type="checkbox" id="isUndocumentedCheckbox" title="Undocumented">
                                        <label class="small ms-1 mb-0" for="isUndocumentedCheckbox">Undoc</label>
                                    </div>
                                </div>
                                <span asp-validation-for="MMSIBillingNumber" class="text-danger small"></span>
                            </div>
                            <div class="col-12 col-md-6">
                                <label asp-for="VoyageNumber" class="form-label fw-bold">Voyage Number <span class="text-danger">*</span></label>
                                <input asp-for="VoyageNumber" type="text" class="form-control" id="VoyageNumber" required>
                                <span asp-validation-for="VoyageNumber" class="text-danger small"></span>
                            </div>
                            <div class="col-12 col-md-6">
                                <label asp-for="Date" class="form-label fw-bold">Date</label>
                                <input asp-for="Date" type="date" class="form-control" value="@(Model.Date != default ? Model.Date.ToString("yyyy-MM-dd") : DateTimeHelper.GetCurrentPhilippineTime().ToString("yyyy-MM-dd"))">
                                <span asp-validation-for="Date" class="text-danger small"></span>
                            </div>
                            <div class="col-12">
                                <label asp-for="PortId" class="form-label fw-bold">Port <span class="text-danger">*</span></label>
                                <select asp-for="PortId" asp-items="@Model.Ports" id="PortSelect" class="form-select js-select2" required style="width: 100%;">
                                    <option value="">-- Select Port --</option>
                                </select>
                                <span asp-validation-for="PortId" class="text-danger small"></span>
                            </div>
                            <div class="col-12">
                                <label asp-for="TerminalId" class="form-label fw-bold">Terminal <span class="text-danger">*</span></label>
                                <select asp-for="TerminalId" asp-items="@Model.Terminals" id="TerminalSelect" class="form-select js-select2" required style="width: 100%;">
                                    <option value="">-- Select Terminal --</option>
                                </select>
                                <span asp-validation-for="TerminalId" class="text-danger small"></span>
                            </div>
                            <div class="col-12">
                                <label asp-for="VesselId" class="form-label fw-bold">Vessel <span class="text-danger">*</span></label>
                                <select asp-for="VesselId" asp-items="@Model.Vessels" class="form-select js-select2" required style="width: 100%;">
                                    <option value="">-- Select Vessel --</option>
                                </select>
                                <span asp-validation-for="VesselId" class="text-danger small"></span>
                            </div>
                            <div class="col-12">
                                <label asp-for="ApOtherTug" class="form-label fw-bold">AP Other Tug</label>
                                <input asp-for="ApOtherTug" step="0.01" type="number" class="form-control" min="0" placeholder="0.00">
                                <span asp-validation-for="ApOtherTug" class="text-danger small"></span>
                            </div>
                        </div>
                    </div>
                </div>
            </div>

            <!-- Right Column: Ticket Selection -->
            <div class="col-12 col-lg-8">
                <div class="card h-100 border-0">
                    <div class="card-header bg-transparent border-0 py-2 d-flex justify-content-between align-items-center">
                        <h6 class="mb-0 fw-bold text-secondary"><i class="bi bi-list-check me-2"></i>Dispatch Tickets</h6>
                        <span class="badge bg-info" id="selectedTicketCount">0 selected</span>
                    </div>
                    <div class="card-body pt-0">
                        <div class="mb-2">
                            <select asp-for="ToBillDispatchTickets" id="DispatchTicketSelect" class="form-select js-example-basic-multiple" name="ToBillDispatchTickets" multiple="multiple" disabled style="width: 100%; min-height: 100px;">
                            </select>
                        </div>
                        <div class="table-responsive" style="max-height: 300px;">
                            <table id="dataTable" class="table table-sm table-hover mb-0" style="font-size: 0.75rem;">
                                <thead class="table-light">
                                    <tr>
                                        <th class="text-center">Dispatch#</th>
                                        <th class="text-center">Tugboat</th>
                                        <th class="text-center">Service</th>
                                        <th class="text-center">Hours</th>
                                        <th class="text-end">Amount</th>
                                    </tr>
                                </thead>
                                <tbody>
                                </tbody>
                            </table>
                        </div>
                        <div class="alert alert-light border mt-2 mb-0 py-2">
                            <div class="row text-center small">
                                <div class="col-4">
                                    <span class="text-muted">Dispatch:</span><br>
                                    <strong class="text-primary">₱<span id="DispatchAmountTotal">0.00</span></strong>
                                </div>
                                <div class="col-4 border-start">
                                    <span class="text-muted">BAF:</span><br>
                                    <strong class="text-primary">₱<span id="BAFAmountTotal">0.00</span></strong>
                                </div>
                                <div class="col-4 border-start">
                                    <span class="text-muted">Total:</span><br>
                                    <strong class="text-success fs-6">₱<span id="OverallTotal">0.00</span></strong>
                                </div>
                            </div>
                        </div>
                    </div>
                </div>
            </div>
        </div>
    </div>

    <div class="modal-footer bg-light">
        <button type="button" class="btn btn-secondary btn-sm" data-bs-dismiss="modal">
            <i class="bi bi-x-circle me-1"></i>Cancel
        </button>
        <button type="button" class="btn btn-primary btn-sm" id="submitCreateBilling">
            <i class="bi bi-save me-1"></i>Create Billing
        </button>
    </div>
</form>

<script>
    $(document).ready(function () {
        let multiSelectVariable = $('.js-example-basic-multiple');
        multiSelectVariable.select2({
            dropdownParent: $('#billingModal')
        });

        // Initialize select2 for all dropdowns within modal
        $('#billingModal .js-select2').select2({
            dropdownParent: $('#billingModal')
        });

        let table = initializeDataTable('#dataTable');
        setupEventListeners();
        handleCheckboxChange();

        function initializeDataTable(selector) {
            if ($.fn.DataTable.isDataTable(selector)) {
                $(selector).DataTable().destroy();
            }
            return $(selector).DataTable({
                paging: false,
                info: false,
                order: [[0, 'asc']],
                lengthChange: false,
                searching: false
            });
        }

        function setupEventListeners() {
            $("#isUndocumentedCheckbox").on("change", handleCheckboxChange);
            $("#UsePrincipalCheckbox").on("change", handleUsePrincipalChange);
            $("#PrincipalSelect").on("change.select2", handlePrincipalChange);
            $("#PortSelect").on("change", handlePortChange);
            $("#submitCreateBilling").on("click", areYouSureToBill);
            multiSelectVariable.on('change', handleDispatchTicketsChange);
        }

        function handleCheckboxChange() {
            const $checkbox = $("#isUndocumentedCheckbox");
            const $inputField = $("#billingNumber");
            const $required = $("#billingNumberRequired");
            const $hiddenInput = $("#IsUndocumented");

            $hiddenInput.val($checkbox.is(":checked") ? "true" : "false");

            if ($checkbox.is(":checked")) {
                $required.hide();
                $inputField.prop("required", false).prop("disabled", true).attr("placeholder", "Auto-generated");
                $inputField.val("");
            } else {
                $required.show();
                $inputField.prop("required", true).prop("disabled", false).attr("placeholder", "BL-XXXX-XXXXXX");
            }
        }

        function handleUsePrincipalChange() {
            const $checkbox = $("#UsePrincipalCheckbox");
            const $principalSection = $("#PrincipalSection");
            const $principalSearch = $("#PrincipalSearch");
            const $principalId = $("#PrincipalId");
            const $billedToContainer = $("#BilledToContainer");

            if ($checkbox.is(":checked")) {
                $principalSection.removeClass("d-none");
                $billedToContainer.removeClass("d-none");
                setTimeout(function() {
                    $principalSearch.focus();
                }, 100);
            } else {
                $principalSection.addClass("d-none");
                $principalSearch.val("");
                $principalId.val("");
                $billedToContainer.addClass("d-none");
                $("#billLocal").prop("checked", true);
            }
        }

        function handlePrincipalChange() {
            const principalId = $("#PrincipalSelect").val();
            if (!principalId) return;
            $.ajax({
                url: '@Url.Action("GetPrincipalDetails", "Billing", new { area = "User" })',
                method: "GET",
                data: { principalId: principalId },
                success: function (data) {
                    updateFields(data);
                }
            });
        }

        // Customer typeahead search - instant suggestions
        let customerSearchTimeout;
        const $customerSearch = $("#CustomerSearch");
        const $customerResults = $("#CustomerSearchResults");
        const $customerId = $("#CustomerId");

        function performCustomerSearch(searchTerm) {
            if (searchTerm.length < 1) {
                $customerResults.empty().addClass('d-none');
                return;
            }

            $.ajax({
                url: '@Url.Action("SearchCustomers", "Billing", new { area = "User" })',
                type: 'GET',
                data: { term: searchTerm },
                success: function(data) {
                    $customerResults.empty();
                    if (Array.isArray(data) && data.length > 0) {
                        $.each(data, function(index, item) {
                            $customerResults.append(
                                $('<a href="#" class="list-group-item list-group-item-action py-2">')
                                    .data('customer', item)
                                    .html('<span>' + item.name + '</span>' +
                                          (item.hasPrincipal ? ' <span class="badge bg-info ms-1">Has Principal</span>' : ''))
                            );
                        });
                        $customerResults.removeClass('d-none');
                    } else {
                        $customerResults.append(
                            $('<div class="list-group-item py-2 text-muted">')
                                .html('<em>No customers found</em>')
                        );
                        $customerResults.removeClass('d-none');
                    }
                },
                error: function() {
                    $customerResults.empty().addClass('d-none');
                }
            });
        }

        // Search on input (with small debounce)
        $customerSearch.on('input', function() {
            clearTimeout(customerSearchTimeout);
            const searchTerm = $(this).val().trim();

            if (searchTerm.length === 0) {
                $customerResults.empty().addClass('d-none');
                $customerId.val('');
                return;
            }

            // Immediate search for first character, debounce for subsequent
            if (searchTerm.length === 1) {
                performCustomerSearch(searchTerm);
            } else {
                customerSearchTimeout = setTimeout(function() {
                    performCustomerSearch(searchTerm);
                }, 150);
            }
        });

        // Show results on focus if has value
        $customerSearch.on('focus', function() {
            const searchTerm = $(this).val().trim();
            if (searchTerm.length > 0 && $customerResults.children().length === 0) {
                performCustomerSearch(searchTerm);
            } else if ($customerResults.children().length > 0) {
                $customerResults.removeClass('d-none');
            }
        });

        // Keyboard navigation
        $customerSearch.on('keydown', function(e) {
            const $items = $customerResults.find('a');
            const $active = $items.filter('.active');

            if (e.key === 'ArrowDown') {
                e.preventDefault();
                if ($active.length === 0) {
                    $items.first().addClass('active');
                } else {
                    $active.removeClass('active').next().addClass('active');
                }
            } else if (e.key === 'ArrowUp') {
                e.preventDefault();
                if ($active.length === 0) {
                    $items.last().addClass('active');
                } else {
                    $active.removeClass('active').prev().addClass('active');
                }
            } else if (e.key === 'Enter') {
                e.preventDefault();
                $active.trigger('click');
            } else if (e.key === 'Escape') {
                $customerResults.addClass('d-none');
            }
        });

        // Handle customer selection from search results
        $customerResults.on('click', 'a', function(e) {
            e.preventDefault();
            const customer = $(this).data('customer');
            $customerSearch.val(customer.name);
            $customerId.val(customer.value);
            $customerResults.empty().addClass('d-none');
            handleCustomerSelected(customer);
        });

        // Close search results when clicking outside
        $(document).on('click', function(e) {
            if (!$(e.target).closest('#CustomerSearch, #CustomerSearchResults, #PrincipalSearch, #PrincipalSearchResults').length) {
                $customerResults.empty().addClass('d-none');
                $principalResults.empty().addClass('d-none');
            }
        });

        function handleCustomerSelected(customer) {
            const $principalCheckboxContainer = $("#PrincipalCheckboxContainer");
            const $principalSection = $("#PrincipalSection");
            const $principalSearch = $("#PrincipalSearch");
            const $principalId = $("#PrincipalId");
            const $billedToContainer = $("#BilledToContainer");
            const $dispatchSelect = $("#DispatchTicketSelect");
            const $isUndocCheckbox = $("#isUndocumentedCheckbox");

            // Reset principal section
            $("#UsePrincipalCheckbox").prop("checked", false);
            $principalSection.addClass("d-none");
            $principalSearch.val("");
            $principalId.val("");
            $billedToContainer.addClass("d-none");

            $dispatchSelect.prop("disabled", false);
            $dispatchSelect.val(null).trigger("change");

            // Check if customer has principal
            if (customer.hasPrincipal) {
                $principalCheckboxContainer.removeClass("d-none");
            } else {
                $principalCheckboxContainer.addClass("d-none");
                $principalSection.addClass("d-none");
            }

            // Set VAT type defaults
            if (customer.vatType === "Vatable") {
                $("#billLocal").prop("checked", true);
            } else {
                $("#billPrincipal").prop("checked", true);
            }

            $isUndocCheckbox.prop("checked", customer.isUndoc === "Undocumented");
            handleCheckboxChange();

            fetchDispatchTickets(customer.value);
        }

        // Principal typeahead search
        let principalSearchTimeout;
        const $principalSearch = $("#PrincipalSearch");
        const $principalResults = $("#PrincipalSearchResults");
        const $principalId = $("#PrincipalId");
        let currentCustomerId = null;

        function performPrincipalSearch(searchTerm) {
            if (!currentCustomerId) {
                $principalResults.empty().addClass('d-none');
                return;
            }

            // Allow empty search term to show all principals
            var requestData = { customerId: currentCustomerId };
            if (searchTerm.length > 0) {
                requestData.term = searchTerm;
            }

            $.ajax({
                url: '@Url.Action("SearchPrincipals", "Billing", new { area = "User" })',
                type: 'GET',
                data: requestData,
                success: function(data) {
                    $principalResults.empty();
                    if (Array.isArray(data) && data.length > 0) {
                        $.each(data, function(index, item) {
                            $principalResults.append(
                                $('<a href="#" class="list-group-item list-group-item-action py-2">')
                                    .data('principal', item)
                                    .html('<span>' + item.name + '</span>')
                            );
                        });
                        $principalResults.removeClass('d-none');
                    } else {
                        $principalResults.append(
                            $('<div class="list-group-item py-2 text-muted">')
                                .html('<em>No principals found</em>')
                        );
                        $principalResults.removeClass('d-none');
                    }
                },
                error: function() {
                    $principalResults.empty().addClass('d-none');
                }
            });
        }

        $principalSearch.on('input', function() {
            clearTimeout(principalSearchTimeout);
            const searchTerm = $(this).val().trim();
            currentCustomerId = $("#CustomerId").val();

            if (searchTerm.length === 0) {
                $principalResults.empty().addClass('d-none');
                $principalId.val('');
                return;
            }

            if (searchTerm.length === 1) {
                performPrincipalSearch(searchTerm);
            } else {
                principalSearchTimeout = setTimeout(function() {
                    performPrincipalSearch(searchTerm);
                }, 150);
            }
        });

        $principalSearch.on('focus', function() {
            const searchTerm = $(this).val().trim();
            currentCustomerId = $("#CustomerId").val();
            // Always show all principals on focus (even with empty search)
            performPrincipalSearch(searchTerm);
        });

        // Handle principal selection
        $principalResults.on('click', 'a', function(e) {
            e.preventDefault();
            const principal = $(this).data('principal');
            $principalSearch.val(principal.name);
            $principalId.val(principal.value);
            $principalResults.empty().addClass('d-none');
        });

        // Keyboard navigation for principal
        $principalSearch.on('keydown', function(e) {
            const $items = $principalResults.find('a');
            const $active = $items.filter('.active');

            if (e.key === 'ArrowDown') {
                e.preventDefault();
                if ($active.length === 0) {
                    $items.first().addClass('active');
                } else {
                    $active.removeClass('active').next().addClass('active');
                }
            } else if (e.key === 'ArrowUp') {
                e.preventDefault();
                if ($active.length === 0) {
                    $items.last().addClass('active');
                } else {
                    $active.removeClass('active').prev().addClass('active');
                }
            } else if (e.key === 'Enter') {
                e.preventDefault();
                $active.trigger('click');
            } else if (e.key === 'Escape') {
                $principalResults.addClass('d-none');
            }
        });

        function fetchDispatchTickets(customerId, selectedIds = null) {
            return $.ajax({
                url: '@Url.Action("GetDispatchTicketsByCustomer", "Billing", new { area = "User" })',
                method: "GET",
                data: { customerId: customerId },
                success: function (data) {
                    const $dispatchSelect = $("#DispatchTicketSelect");
                    $dispatchSelect.empty();
                    if (Array.isArray(data) && data.length > 0) {
                        $.each(data, function (index, item) {
                            let selected = selectedIds && selectedIds.includes(parseInt(item.value));
                            $dispatchSelect.append($('<option>', {
                                value: item.value,
                                text: item.text,
                                selected: selected
                            }));
                        });
                    }
                    $dispatchSelect.trigger("change");
                }
            });
        }

        function updateTicketCount(count) {
            $("#selectedTicketCount").text(count + " selected");
        }

        function handlePortChange() {
            const portId = $("#PortSelect").val();
            $.ajax({
                url: '@Url.Action("ChangeTerminal", "DispatchTicket", new { area = "User" })',
                type: "GET",
                data: { portId: portId },
                success: function (data) {
                    const $terminalSelect = $("#TerminalSelect");
                    $terminalSelect.empty().append('<option value="">Select Terminal</option>');
                    if (Array.isArray(data)) {
                        $.each(data, function (index, item) {
                            $terminalSelect.append($('<option>', { value: item.value, text: item.text }));
                        });
                    }
                }
            });
        }

        function handleDispatchTicketsChange() {
            const selectedTickets = $("#DispatchTicketSelect").val();
            updateTicketCount(selectedTickets?.length || 0);
            if (!selectedTickets || selectedTickets.length === 0) {
                updateDispatchTable([]);
                return;
            }
            $.ajax({
                url: '@Url.Action("GetDispatchTickets", "Billing", new { area = "User" })',
                type: 'POST',
                data: { dispatchTicketIds: selectedTickets },
                success: function (result) {
                    updateDispatchTable(result.data);
                }
            });
        }

        function updateDispatchTable(data) {
            let totalDispatchAmount = 0;
            let totalBAFAmount = 0;

            table.destroy();
            const $tbody = $('#dataTable tbody').empty();

            $.each(data || [], function (index, value) {
                totalDispatchAmount += value.dispatchNetRevenue;
                totalBAFAmount += value.bafNetRevenue;
                const totalAmount = value.dispatchNetRevenue + value.bafNetRevenue;
                $tbody.append(`
                    <tr>
                        <td class="text-center">${value.dispatchNumber}</td>
                        <td class="text-center">${value.tugboat?.tugboatName || '-'}</td>
                        <td class="text-center">${value.service?.serviceName || '-'}</td>
                        <td class="text-center">${(value.totalHours || 0).toFixed(2)}</td>
                        <td class="text-end">₱${formatNumber(totalAmount)}</td>
                    </tr>
                `);
            });

            $("#DispatchAmountTotal").text(formatNumber(totalDispatchAmount));
            $("#BAFAmountTotal").text(formatNumber(totalBAFAmount));
            $("#OverallTotal").text(formatNumber(totalDispatchAmount + totalBAFAmount));
            updateTicketCount(data?.length || 0);

            table = initializeDataTable('#dataTable');
        }

        function areYouSureToBill(event) {
            event.preventDefault();
            const form = document.getElementById("billingCreateForm");
            if (!form.checkValidity()) {
                form.reportValidity();
                return;
            }

            const selectedTickets = $("#DispatchTicketSelect").val();
            if (!selectedTickets || selectedTickets.length === 0) {
                Swal.fire({
                    title: "No Tickets Selected",
                    text: "Please select at least one dispatch ticket to bill.",
                    icon: "warning"
                });
                return;
            }

            Swal.fire({
                title: "Submit Billing?",
                text: "Review all details before proceeding.",
                icon: "question",
                showCancelButton: true,
                confirmButtonText: "Yes, submit"
            }).then((result) => {
                if (result.isConfirmed) {
                    submitCreateForm();
                }
            });
        }

        function submitCreateForm() {
            const form = $('#billingCreateForm');
            const formData = form.serialize();

            $.ajax({
                url: '@Url.Action("Create", "Billing", new { area = "User" })',
                type: 'POST',
                data: formData,
                success: function (response) {
                    if (response.success) {
                        $('#billingModal').modal('hide');
                        Swal.fire({
                            title: "Success!",
                            text: response.message,
                            icon: "success"
                        }).then(() => {
                            if (response.redirectUrl) {
                                window.location.href = response.redirectUrl;
                            } else {
                                location.reload();
                            }
                        });
                    } else {
                        Swal.fire({
                            title: "Error",
                            text: response.message || "Failed to create billing.",
                            icon: "error"
                        });
                    }
                },
                error: function (xhr) {
                    Swal.fire({
                        title: "Error",
                        text: "An error occurred while creating the billing.",
                        icon: "error"
                    });
                }
            });
        }
    });
</script>
