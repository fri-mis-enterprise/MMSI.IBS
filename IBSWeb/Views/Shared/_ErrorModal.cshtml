@{
    var message = ViewData["message"] as string ?? "You don't have permission to access this feature.";
    var title = ViewData["title"] as string ?? "Access Denied";
}

<div class="error-modal-content text-center py-4">
    <div class="mb-3">
        <i class="bi bi-lock-fill text-danger" style="font-size: 4rem;"></i>
    </div>
    
    <h4 class="text-danger mb-3">@title</h4>
    
    <p class="text-muted mb-4">@message</p>
    
    <div class="alert alert-warning" role="alert">
        <small>
            <i class="bi bi-info-circle me-1"></i>
            Please contact your administrator to request access to this feature.
        </small>
    </div>
    
    <button type="button" class="btn btn-secondary" data-bs-dismiss="modal">
        <i class="bi bi-x-circle me-1"></i>
        Close
    </button>
</div>

<script>
    // Auto-initialize Bootstrap modal if not already initialized
    document.addEventListener('DOMContentLoaded', function () {
        let modalElement = document.querySelector('.modal');
        if (modalElement) {
            let modal = bootstrap.Modal.getInstance(modalElement);
            if (!modal) {
                modal = new bootstrap.Modal(modalElement);
                modal.show();
            }
        }
    });
</script>

<style>
    .error-modal-content {
        padding: 2rem;
    }
    
    .error-modal-content .bi-lock-fill {
        opacity: 0.8;
    }
    
    .error-modal-content h4 {
        font-weight: 600;
    }
</style>
