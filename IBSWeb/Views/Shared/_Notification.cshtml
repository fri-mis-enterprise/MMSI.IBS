@if (TempData["success"] != null)
{
    <script>
        Swal.fire('Success', '@TempData["success"]', 'success');
    </script>
}

@if (TempData["error"] != null)
{
    <script>
        Swal.fire('Error', '@TempData["error"]', 'error');
    </script>
}

@if (TempData["Denied"] != null)
{
    <script>
        Swal.fire('Oops...', '@TempData["Denied"]', 'error');
    </script>
}

@if (TempData["warning"] != null)
{
    <script>
        Swal.fire('Warning', '@TempData["warning"]', 'warning');
    </script>
}

@if (TempData["info"] != null)
{
    <script>
        Swal.fire('Info', '@TempData["info"]', 'info');
    </script>
}
